<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <runtime>
    <!--
      Opt out of WPF's legacy UI Automation accessibility behavior so that screen-reader
      announcements (LiveRegionChanged / notification events) are actually forwarded to
      clients such as Windows Narrator. Without this, WPF on .NET Framework accepts the
      RaiseAutomationEvent/notification call but silently drops it, so nothing is announced.
      Each switch builds on the previous one, so all three are disabled together.
    -->
      <AppContextSwitchOverrides value="Switch.UseLegacyAccessibilityFeatures=false;Switch.UseLegacyAccessibilityFeatures.2=false;Switch.UseLegacyAccessibilityFeatures.3=false;Switch.UseLegacyAccessibilityFeatures.4=false" />
  </runtime>
</configuration>
