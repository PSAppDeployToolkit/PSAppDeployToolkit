<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net472;net10.0-windows10.0.26100.0</TargetFrameworks>
    <OutputType>Library</OutputType>
    <RootNamespace>PSADT.Interop</RootNamespace>
    <AssemblyName>PSADT.Interop</AssemblyName>
    <Product>PSAppDeployToolkit Win32 Native Methods Library</Product>
    <AssemblyTitle>PSAppDeployToolkit Win32 Native Methods Library</AssemblyTitle>
    <AssemblyDescription>This assembly provides Win32 library access to all areas of PSAppDeployToolkit.</AssemblyDescription>
    <DebugSymbols>false</DebugSymbols>
    <DebugType>none</DebugType>
    <NoWarn>SYSLIB1045;SYSLIB1054</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="PSADT" />
    <InternalsVisibleTo Include="PSADT.ClientServer.Client" />
    <InternalsVisibleTo Include="PSADT.ClientServer.Client.Compatible" />
    <InternalsVisibleTo Include="PSADT.ClientServer.Client.Launcher" />
    <InternalsVisibleTo Include="PSADT.ClientServer.Client.Launcher.Compatible" />
    <InternalsVisibleTo Include="PSADT.ClientServer.Common" />
    <InternalsVisibleTo Include="PSADT.ClientServer.Server" />
    <InternalsVisibleTo Include="PSADT.UserInterface" />
    <InternalsVisibleTo Include="PSADT.UserInterface.TestHarness" />
    <InternalsVisibleTo Include="PSAppDeployToolkit" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Windows.CsWin32" Version="0.3.269">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="System.Memory" Version="4.6.3" />
    <PackageReference Include="System.Runtime.CompilerServices.Unsafe" Version="6.1.2" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net472'">
    <PackageReference Include="Microsoft.Windows.SDK.Contracts" Version="10.0.26100.7705" />
  </ItemGroup>

  <PropertyGroup>
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
  </PropertyGroup>

  <Target Name="PsadtNativeCompilation" BeforeTargets="DispatchToInnerBuilds" Condition="'$(IsCrossTargetingBuild)' == 'true'">
    <Exec Command="&quot;$(MSBuildProgramFiles32)\Microsoft Visual Studio\Installer\vswhere.exe&quot; -latest -requires Microsoft.Component.MSBuild -find MSBuild\**\Bin\MSBuild.exe" ConsoleToMSBuild="true" StandardOutputImportance="Low">
      <Output TaskParameter="ConsoleOutput" PropertyName="PsadtNativeMsBuildExe" />
    </Exec>
    <Error Condition="'$(PsadtNativeMsBuildExe)' == ''" Text="Failed to locate Visual Studio MSBuild.exe required to build PSADT.Native.slnx." />
    <Exec Command="&quot;$(PsadtNativeMsBuildExe)&quot; &quot;$(MSBuildThisFileDirectory)..\..\..\PSADT.Native.slnx&quot; -target:Build -property:Configuration=$(Configuration);Platform=x86 -nologo -nodeReuse:false -verbosity:quiet" ConsoleToMSBuild="true" />
    <Exec Command="&quot;$(PsadtNativeMsBuildExe)&quot; &quot;$(MSBuildThisFileDirectory)..\..\..\PSADT.Native.slnx&quot; -target:Build -property:Configuration=$(Configuration);Platform=x64 -nologo -nodeReuse:false -verbosity:quiet" ConsoleToMSBuild="true" />
    <Exec Command="&quot;$(PsadtNativeMsBuildExe)&quot; &quot;$(MSBuildThisFileDirectory)..\..\..\PSADT.Native.slnx&quot; -target:Build -property:Configuration=$(Configuration);Platform=ARM64 -nologo -nodeReuse:false -verbosity:quiet" ConsoleToMSBuild="true" />
  </Target>

  <Target Name="PsadtNativeVerification" BeforeTargets="DispatchToInnerBuilds" DependsOnTargets="PsadtNativeCompilation" Condition="'$(IsCrossTargetingBuild)' == 'true'">
    <Error Condition="!Exists('..\..\PSADT.Native\PSADT.Native\bin\Win32\$(Configuration)\PSADT.Native.dll')" Text="Missing required native asset: ..\..\PSADT.Native\PSADT.Native\bin\Win32\$(Configuration)\PSADT.Native.dll" />
    <Error Condition="!Exists('..\..\PSADT.Native\PSADT.Native\bin\x64\$(Configuration)\PSADT.Native.dll')" Text="Missing required native asset: ..\..\PSADT.Native\PSADT.Native\bin\x64\$(Configuration)\PSADT.Native.dll" />
    <Error Condition="!Exists('..\..\PSADT.Native\PSADT.Native\bin\ARM64\$(Configuration)\PSADT.Native.dll')" Text="Missing required native asset: ..\..\PSADT.Native\PSADT.Native\bin\ARM64\$(Configuration)\PSADT.Native.dll" />
  </Target>

  <Target Name="PsadtNativeCopyToOutput" BeforeTargets="GetCopyToOutputDirectoryItems" Condition="'$(IsCrossTargetingBuild)' != 'true'">
    <ItemGroup>
      <ContentWithTargetPath Include="..\..\PSADT.Native\PSADT.Native\bin\Win32\$(Configuration)\PSADT.Native.dll">
        <TargetPath>X86\PSADT.Native.dll</TargetPath>
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </ContentWithTargetPath>
      <ContentWithTargetPath Include="..\..\PSADT.Native\PSADT.Native\bin\x64\$(Configuration)\PSADT.Native.dll">
        <TargetPath>X64\PSADT.Native.dll</TargetPath>
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </ContentWithTargetPath>
      <ContentWithTargetPath Include="..\..\PSADT.Native\PSADT.Native\bin\ARM64\$(Configuration)\PSADT.Native.dll">
        <TargetPath>Arm64\PSADT.Native.dll</TargetPath>
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </ContentWithTargetPath>
    </ItemGroup>
  </Target>
</Project>
