<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net472;net10.0</TargetFrameworks>
    <OutputType>Library</OutputType>
    <RootNamespace>PSAppDeployToolkit</RootNamespace>
    <AssemblyName>PSAppDeployToolkit</AssemblyName>
    <Product>PSAppDeployToolkit PowerShell Module Library</Product>
    <AssemblyTitle>PSAppDeployToolkit PowerShell Module Library</AssemblyTitle>
    <AssemblyDescription>This assembly contains all PowerShell-specific elements of the solution.</AssemblyDescription>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <NoWarn>SYSLIB1045</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="PSADT.ClientServer.Server" />
    <InternalsVisibleTo Include="PSADT.UserInterface" />
    <InternalsVisibleTo Include="PSADT.UserInterface.TestHarness" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="PowerShellStandard.Library" Version="5.1.1" PrivateAssets="all" ExcludeAssets="runtime" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\PSADT.Interop\PSADT.Interop.csproj" />
    <ProjectReference Include="..\PSADT\PSADT.csproj" />
  </ItemGroup>
</Project>
