<UserControl
    x:Class="Fluence.Wpf.Demo.Pages.GalleryTreesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Fluence.Wpf.Demo.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="clr-namespace:Fluence.Wpf.Controls;assembly=Fluence.Wpf"
    xmlns:uicore="clr-namespace:Fluence.Wpf;assembly=Fluence.Wpf"
    d:DesignHeight="900"
    d:DesignWidth="900"
    mc:Ignorable="d">
    <ui:SmoothScrollViewer Style="{StaticResource GalleryPageScrollViewerStyle}">
        <StackPanel Style="{StaticResource GalleryPageContentStackStyle}">
            <TextBlock Style="{StaticResource PageTitleStyle}" Text="Trees" />
            <TextBlock Style="{StaticResource SectionDescriptionStyle}" Text="TreeView presents nested items that users can expand, collapse, and select." />


            <ContentControl x:Name="DemoSampleSlot01DemoContentHost" Visibility="Collapsed">
                <ui:TreeView
                    x:Name="HierarchyTreeView"
                    MaxHeight="260"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                    <ui:TreeViewItem Header="Workspace" IsExpanded="True">
                        <ui:TreeViewItem Header="Pages" IsExpanded="True">
                            <ui:TreeViewItem Header="GalleryButtonsPage.xaml" />
                            <ui:TreeViewItem Header="GalleryTreesPage.xaml" />
                            <ui:TreeViewItem Header="GalleryDataPage.xaml" />
                        </ui:TreeViewItem>
                        <ui:TreeViewItem Header="Samples">
                            <ui:TreeViewItem Header="Buttons" />
                            <ui:TreeViewItem Header="Trees" />
                        </ui:TreeViewItem>
                    </ui:TreeViewItem>
                    <ui:TreeViewItem Header="Resources">
                        <ui:TreeViewItem Header="DemoSharedStyles.xaml" />
                    </ui:TreeViewItem>
                </ui:TreeView>
            </ContentControl>
            <local:DemoSampleControl SampleDescription="Use TreeViewItem nesting for compact folder, outline, or category hierarchies." />


            <ContentControl x:Name="DemoSampleSlot02DemoContentHost" Visibility="Collapsed">
                <ui:TreeView
                    x:Name="SelectionTreeView"
                    MaxHeight="260"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                    <ui:TreeViewItem Header="Inbox" IsExpanded="True">
                        <ui:TreeViewItem Header="Priority" IsExpanded="True">
                            <ui:TreeViewItem Header="Contract review" />
                            <ui:TreeViewItem Header="Customer follow-up" />
                        </ui:TreeViewItem>
                        <ui:TreeViewItem Header="Later">
                            <ui:TreeViewItem Header="Design notes" />
                            <ui:TreeViewItem Header="Release checklist" />
                        </ui:TreeViewItem>
                    </ui:TreeViewItem>
                    <ui:TreeViewItem Header="Archive">
                        <ui:TreeViewItem Header="March" />
                        <ui:TreeViewItem Header="April" />
                    </ui:TreeViewItem>
                </ui:TreeView>
            </ContentControl>
            <local:DemoSampleControl SampleDescription="Handle SelectedItemChanged when selecting a node should update related content." />


            <ContentControl x:Name="DemoSampleSlot03DemoContentHost" Visibility="Collapsed">
                <ui:TreeView
                    x:Name="MultiSelectTreeView"
                    MaxHeight="260"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    SelectionMode="{x:Static uicore:TreeViewSelectionMode.Multiple}">
                    <ui:TreeViewItem Header="Documents" IsExpanded="True">
                        <ui:TreeViewItem Header="Contracts" />
                        <ui:TreeViewItem Header="Invoices" />
                        <ui:TreeViewItem Header="Receipts" />
                    </ui:TreeViewItem>
                    <ui:TreeViewItem Header="Pictures" IsExpanded="True">
                        <ui:TreeViewItem Header="Screenshots" />
                        <ui:TreeViewItem Header="Archive" />
                    </ui:TreeViewItem>
                </ui:TreeView>
            </ContentControl>
            <local:DemoSampleControl SampleDescription="Use multiple selection when people need to select several nodes from the same hierarchy." />


            <ContentControl x:Name="DemoSampleSlot04DemoContentHost" Visibility="Collapsed">
                <ui:TreeView
                    x:Name="ExpansionTreeView"
                    MaxHeight="260"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                    <ui:TreeViewItem Header="Project" IsExpanded="True">
                        <ui:TreeViewItem Header="Source" IsExpanded="True">
                            <ui:TreeViewItem Header="Controls" />
                            <ui:TreeViewItem Header="Themes" />
                        </ui:TreeViewItem>
                        <ui:TreeViewItem Header="Tests">
                            <ui:TreeViewItem Header="Control tests" />
                            <ui:TreeViewItem Header="Demo tests" />
                        </ui:TreeViewItem>
                    </ui:TreeViewItem>
                </ui:TreeView>
            </ContentControl>
            <ContentControl x:Name="DemoSampleSlot04RightRailContentHost" Visibility="Collapsed">
                <StackPanel
                    x:Name="TreeExpansionActionsPanel"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    <ui:Button
                        MinWidth="140"
                        Click="ExpandAll_Click"
                        Content="Expand all" />
                    <ui:Button
                        MinWidth="140"
                        Margin="{DynamicResource DemoTextTopGapMargin}"
                        Click="CollapseAll_Click"
                        Content="Collapse all" />
                </StackPanel>
            </ContentControl>
            <local:DemoSampleControl SampleDescription="Set IsExpanded directly, or walk the item collection when a command controls the tree." />
        </StackPanel>
    </ui:SmoothScrollViewer>
</UserControl>
