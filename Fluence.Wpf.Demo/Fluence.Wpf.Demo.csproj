<Project Sdk="Microsoft.NET.Sdk.WindowsDesktop">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFrameworks>net472;net10.0-windows10.0.26100.0</TargetFrameworks>
    <UseWPF>true</UseWPF>
    <RootNamespace>Fluence.Wpf.Demo</RootNamespace>
    <AssemblyName>Fluence.Wpf.Demo</AssemblyName>
    <ApplicationIcon>..\assets\Fluence_Icon_Light.ico</ApplicationIcon>
    <GenerateAssemblyInfo>true</GenerateAssemblyInfo>
    <NoWarn>$(NoWarn);CS1591;VSTHRD001;MA0045</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Fluence.Wpf\Fluence.Wpf.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Page Update="Properties\DesignTimeResources.xaml">
      <Generator>MSBuild:Compile</Generator>
      <ContainsDesignTimeResources>true</ContainsDesignTimeResources>
    </Page>
    <Resource Include="Resources\ControlImages\*.png" />
    <Resource Include="Resources\Fluence_Lockup_SideBySide_*.png" />
    <Resource Include="Resources\SegoeFluentIcons.tsv" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net472'">
    <PackageReference Include="Meziantou.Polyfill" Version="1.0.156">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <PropertyGroup>
    <MeziantouPolyfill_IncludedPolyfills>
      M:System.String.Replace|
      T:System.Threading.Lock|
    </MeziantouPolyfill_IncludedPolyfills>
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
  </PropertyGroup>

  <PropertyGroup Condition="'$(TargetFramework)' == 'net10.0-windows10.0.26100.0'">
    <NoWarn>$(NoWarn);RCS1255</NoWarn>
  </PropertyGroup>

</Project>
