<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Fluence.Wpf.Controls"
    xmlns:ui="clr-namespace:Fluence.Wpf">

    <Style x:Key="InfoBarCloseButtonFocusVisual">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Grid>
                        <Border
                            Margin="-3"
                            BorderBrush="{DynamicResource FocusStrokeColorOuterBrush}"
                            BorderThickness="2"
                            CornerRadius="{DynamicResource ControlCornerRadius}" />
                        <Border
                            Margin="-2"
                            BorderBrush="{DynamicResource FocusStrokeColorInnerBrush}"
                            BorderThickness="1"
                            CornerRadius="3" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        Subtle plate for the close button. WinUI InfoBar.xaml swaps the close button's
        brushes to the AppBarButton set: transparent rest plate, SubtleFillColorSecondary
        hover / SubtleFillColorTertiary press, primary-to-secondary text foreground, no
        border, ControlCornerRadius rounding (see TeachingTip.xaml / PipsPager.xaml for
        the same plate pattern). The template is required: a stock Button without one
        falls back to the OS default chrome, whose internal triggers paint square
        corners and legacy hover colors regardless of the Background property.
    -->
    <Style x:Key="InfoBarCloseButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource InfoBarCloseButtonFocusVisual}" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border
                        x:Name="ButtonPlate"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{DynamicResource ControlCornerRadius}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonPlate" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonPlate" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Width" Value="28" />
    </Style>

    <Style TargetType="{x:Type controls:InfoBar}">
        <Setter Property="Background" Value="{DynamicResource SystemFillColorAttentionBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="FontFamily" Value="{DynamicResource FluentFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Opacity" Value="0" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:InfoBar}">
                    <Border
                        x:Name="RootBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        ClipToBounds="False"
                        CornerRadius="{TemplateBinding CornerRadius}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!--  Severity indicator bar  -->
                            <Border
                                x:Name="IndicatorBar"
                                Grid.Column="0"
                                Background="{DynamicResource SystemFillColorAttentionBrush}" />

                            <!--  Content area  -->
                            <Grid Grid.Column="1" Margin="{TemplateBinding Padding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!--  Icon area  -->
                                <Grid
                                    x:Name="IconArea"
                                    Grid.Column="0"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center">
                                    <!--  Default severity icon (shown when Icon DP is null)  -->
                                    <TextBlock
                                        x:Name="DefaultIcon"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                        FontSize="16"
                                        Foreground="{DynamicResource SystemFillColorAttentionBrush}"
                                        Text="&#xE946;"
                                        Visibility="Collapsed" />
                                    <!--  Custom icon override (shown when Icon DP is set)  -->
                                    <ContentPresenter
                                        x:Name="CustomIconPresenter"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Content="{TemplateBinding Icon}"
                                        TextElement.Foreground="{TemplateBinding Foreground}">
                                        <ContentPresenter.Resources>
                                            <!--  Custom icon follows the InfoBar title text (SplitButton precedent); the default severity icon above stays semantic. A consumer's local Foreground still wins.  -->
                                            <Style TargetType="{x:Type controls:FontIcon}">
                                                <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type controls:InfoBar}}}" />
                                            </Style>
                                        </ContentPresenter.Resources>
                                    </ContentPresenter>
                                </Grid>

                                <!--  Title and message  -->
                                <StackPanel
                                    Grid.Column="1"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center">
                                    <TextBlock
                                        x:Name="TitleTextBlock"
                                        FontFamily="{TemplateBinding FontFamily}"
                                        FontSize="{TemplateBinding FontSize}"
                                        FontWeight="SemiBold"
                                        Foreground="{TemplateBinding Foreground}"
                                        Text="{TemplateBinding Title}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        x:Name="MessageTextBlock"
                                        Margin="0,2,0,0"
                                        FontFamily="{TemplateBinding FontFamily}"
                                        FontSize="{TemplateBinding FontSize}"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                        Text="{TemplateBinding Message}"
                                        TextWrapping="Wrap" />
                                </StackPanel>

                                <!--  Action button slot  -->
                                <ContentPresenter
                                    x:Name="ActionPresenter"
                                    Grid.Column="2"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    Content="{TemplateBinding ActionButton}" />

                                <!--  Close button  -->
                                <Button
                                    x:Name="PART_CloseButton"
                                    Grid.Column="3"
                                    VerticalAlignment="Center"
                                    AutomationProperties.Name="Close"
                                    Style="{StaticResource InfoBarCloseButtonStyle}"
                                    ToolTip="Close">
                                    <controls:FontIcon
                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                        Glyph="&#xE711;"
                                        IconFontSize="12"
                                        IsHitTestVisible="False" />
                                </Button>
                            </Grid>
                        </Grid>
                        <!--  WI-3 B14: SeverityLevels VSM group - WPF opacity-pulse approximation of WinUI instant VisualState.Setters  -->
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="SeverityLevels">
                                <VisualState x:Name="Informational">
                                    <Storyboard>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="IndicatorBar" Storyboard.TargetProperty="Opacity">
                                            <SplineDoubleKeyFrame
                                                KeySpline="0.8,0,0,1"
                                                KeyTime="0:0:0"
                                                Value="0" />
                                            <SplineDoubleKeyFrame
                                                KeySpline="0.8,0,0,1"
                                                KeyTime="0:0:0.1"
                                                Value="1" />
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Success">
                                    <Storyboard>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="IndicatorBar" Storyboard.TargetProperty="Opacity">
                                            <SplineDoubleKeyFrame
                                                KeySpline="0.8,0,0,1"
                                                KeyTime="0:0:0"
                                                Value="0" />
                                            <SplineDoubleKeyFrame
                                                KeySpline="0.8,0,0,1"
                                                KeyTime="0:0:0.1"
                                                Value="1" />
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Warning">
                                    <Storyboard>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="IndicatorBar" Storyboard.TargetProperty="Opacity">
                                            <SplineDoubleKeyFrame
                                                KeySpline="0.8,0,0,1"
                                                KeyTime="0:0:0"
                                                Value="0" />
                                            <SplineDoubleKeyFrame
                                                KeySpline="0.8,0,0,1"
                                                KeyTime="0:0:0.1"
                                                Value="1" />
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Error">
                                    <Storyboard>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="IndicatorBar" Storyboard.TargetProperty="Opacity">
                                            <SplineDoubleKeyFrame
                                                KeySpline="0.8,0,0,1"
                                                KeyTime="0:0:0"
                                                Value="0" />
                                            <SplineDoubleKeyFrame
                                                KeySpline="0.8,0,0,1"
                                                KeyTime="0:0:0.1"
                                                Value="1" />
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!--  IsOpen: visible state + open/close animation  -->
                        <Trigger Property="IsOpen" Value="True">
                            <Setter Property="Opacity" Value="1" />
                            <Setter Property="Visibility" Value="Visible" />
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                            <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}" />
                                        </ObjectAnimationUsingKeyFrames>
                                        <!--  ControlFastAnimationDuration (167 ms) open fade  -->
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity">
                                            <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                                            <SplineDoubleKeyFrame
                                                KeySpline="0.8,0,0,1"
                                                KeyTime="0:0:0.167"
                                                Value="1" />
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <!--  ControlFastAnimationDuration (167 ms) close fade  -->
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity">
                                            <SplineDoubleKeyFrame
                                                KeySpline="0.8,0,0,1"
                                                KeyTime="0:0:0.167"
                                                Value="0" />
                                        </DoubleAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                            <DiscreteObjectKeyFrame KeyTime="0:0:0.167" Value="{x:Static Visibility.Collapsed}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>

                        <!--  IsClosable hidden  -->
                        <Trigger Property="IsClosable" Value="False">
                            <Setter TargetName="PART_CloseButton" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <!--  IsIconVisible hidden  -->
                        <Trigger Property="IsIconVisible" Value="False">
                            <Setter TargetName="IconArea" Property="Margin" Value="0" />
                            <Setter TargetName="IconArea" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <!--  Custom icon override: when Icon is null show default, otherwise show custom  -->
                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="DefaultIcon" Property="Visibility" Value="Visible" />
                            <Setter TargetName="CustomIconPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <!--  Title empty → collapse  -->
                        <Trigger Property="Title" Value="{x:Null}">
                            <Setter TargetName="TitleTextBlock" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Title" Value="">
                            <Setter TargetName="TitleTextBlock" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <!--  Message empty → collapse  -->
                        <Trigger Property="Message" Value="{x:Null}">
                            <Setter TargetName="MessageTextBlock" Property="Margin" Value="0" />
                            <Setter TargetName="MessageTextBlock" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Message" Value="">
                            <Setter TargetName="MessageTextBlock" Property="Margin" Value="0" />
                            <Setter TargetName="MessageTextBlock" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <!--  ActionButton empty → collapse  -->
                        <Trigger Property="ActionButton" Value="{x:Null}">
                            <Setter TargetName="ActionPresenter" Property="Margin" Value="0" />
                            <Setter TargetName="ActionPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <!--  Severity: Informational (default)  -->
                        <Trigger Property="Severity" Value="{x:Static ui:InfoBarSeverity.Informational}">
                            <Setter Property="Background" Value="{DynamicResource SystemFillColorAttentionBackgroundBrush}" />
                            <Setter TargetName="IndicatorBar" Property="Background" Value="{DynamicResource SystemFillColorAttentionBrush}" />
                            <Setter TargetName="DefaultIcon" Property="Foreground" Value="{DynamicResource SystemFillColorAttentionBrush}" />
                            <Setter TargetName="DefaultIcon" Property="Text" Value="&#xE946;" />
                        </Trigger>

                        <!--  Severity: Success  -->
                        <Trigger Property="Severity" Value="{x:Static ui:InfoBarSeverity.Success}">
                            <Setter Property="Background" Value="{DynamicResource SystemFillColorSuccessBackgroundBrush}" />
                            <Setter TargetName="IndicatorBar" Property="Background" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                            <Setter TargetName="DefaultIcon" Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                            <Setter TargetName="DefaultIcon" Property="Text" Value="&#xE73E;" />
                        </Trigger>

                        <!--  Severity: Warning  -->
                        <Trigger Property="Severity" Value="{x:Static ui:InfoBarSeverity.Warning}">
                            <Setter Property="Background" Value="{DynamicResource SystemFillColorCautionBackgroundBrush}" />
                            <Setter TargetName="IndicatorBar" Property="Background" Value="{DynamicResource SystemFillColorCautionBrush}" />
                            <Setter TargetName="DefaultIcon" Property="Foreground" Value="{DynamicResource SystemFillColorCautionBrush}" />
                            <Setter TargetName="DefaultIcon" Property="Text" Value="&#xE7BA;" />
                        </Trigger>

                        <!--  Severity: Error  -->
                        <Trigger Property="Severity" Value="{x:Static ui:InfoBarSeverity.Error}">
                            <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBackgroundBrush}" />
                            <Setter TargetName="IndicatorBar" Property="Background" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                            <Setter TargetName="DefaultIcon" Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                            <Setter TargetName="DefaultIcon" Property="Text" Value="&#xEA39;" />
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Visibility" Value="Collapsed" />
    </Style>

</ResourceDictionary>
