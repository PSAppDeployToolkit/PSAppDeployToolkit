<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Fluence.Wpf.Controls">

    <!--
        Fluent Design ContextMenu + MenuItem + Separator styles.
        Authority: WinUI 3 MenuFlyout_themeresources.xaml (brush keys, item heights, padding).
        Note: No DropShadowEffect on the popup Border - WPF bitmap effects on a Border with
        CornerRadius produce artifacts in a Popup (see DropDownButton.xaml). System
        HasDropShadow (popup-level) is used instead.
        SharedSizeGroup "MenuIconCol" aligns icons across all items in a menu.
    -->

    <!--  ═══════════════════════════════════════════════════════════  -->
    <!--  ContextMenu container  -->
    <!--  ═══════════════════════════════════════════════════════════  -->
    <Style TargetType="{x:Type controls:ContextMenu}">
        <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorTertiaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SurfaceStrokeColorFlyoutBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontFamily" Value="{DynamicResource FluentFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="HasDropShadow" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ContextMenu}">
                    <Border
                        MinWidth="180"
                        Padding="2"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{DynamicResource OverlayCornerRadius}"
                        UseLayoutRounding="True">
                        <Grid Grid.IsSharedSizeScope="True">
                            <ItemsPresenter />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <!--  ═══════════════════════════════════════════════════════════  -->
    <!--  MenuItem  -->
    <!--  Handles SubmenuItem (leaf) and SubmenuHeader (has submenu).  -->
    <!--  TopLevelItem / TopLevelHeader handled by same template with  -->
    <!--  appropriate visibility triggers.  -->
    <!--  ═══════════════════════════════════════════════════════════  -->
    <Style TargetType="{x:Type controls:MenuItem}">
        <Setter Property="Background" Value="{DynamicResource SubtleFillColorTransparentBrush}" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="FontFamily" Value="{DynamicResource FluentFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:MenuItem}">
                    <Border
                        x:Name="Bd"
                        Margin="2,1"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{DynamicResource ControlCornerRadius}">
                        <Grid MinHeight="32" Margin="4,0">
                            <Grid.ColumnDefinitions>
                                <!--  Icon / checkmark - shared-size keeps all items aligned  -->
                                <ColumnDefinition Width="20" SharedSizeGroup="MenuIconCol" />
                                <!--  Gap  -->
                                <ColumnDefinition Width="8" />
                                <!--  Header text  -->
                                <ColumnDefinition Width="*" />
                                <!--  Keyboard shortcut  -->
                                <ColumnDefinition Width="Auto" />
                                <!--  Gap + submenu arrow  -->
                                <ColumnDefinition Width="20" />
                            </Grid.ColumnDefinitions>

                            <!--  Submenu popup  -->
                            <Popup
                                x:Name="PART_Popup"
                                AllowsTransparency="True"
                                Focusable="False"
                                IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                Placement="Right"
                                PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                PopupAnimation="None">
                                <!--  SubMenuBorder: slide-in from X=-8 on open (167ms ControlFastOutSlowIn).  -->
                                <Border
                                    x:Name="SubMenuBorder"
                                    MinWidth="180"
                                    Padding="2"
                                    Background="{DynamicResource SolidBackgroundFillColorTertiaryBrush}"
                                    BorderBrush="{DynamicResource SurfaceStrokeColorFlyoutBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{DynamicResource OverlayCornerRadius}"
                                    UseLayoutRounding="True">
                                    <Border.RenderTransform>
                                        <TranslateTransform x:Name="SubMenuTranslate" X="-8" />
                                    </Border.RenderTransform>
                                    <Grid Grid.IsSharedSizeScope="True">
                                        <ItemsPresenter x:Name="ItemsPresenter" KeyboardNavigation.DirectionalNavigation="Cycle" />
                                    </Grid>
                                </Border>
                            </Popup>

                            <!--  Checkmark (visible when IsChecked=True and no custom Icon)  -->
                            <TextBlock
                                x:Name="CheckMark"
                                Grid.Column="0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="14"
                                Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                Text="&#xE73E;"
                                Visibility="Collapsed" />

                            <!--  Custom icon (MenuItem.Icon property)  -->
                            <ContentPresenter
                                x:Name="Icon"
                                Grid.Column="0"
                                Width="16"
                                Height="16"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding Icon}"
                                Visibility="Collapsed" />

                            <!--  Header text / content  -->
                            <ContentPresenter
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                ContentSource="Header"
                                RecognizesAccessKey="True"
                                TextElement.FontFamily="{TemplateBinding FontFamily}"
                                TextElement.FontSize="{TemplateBinding FontSize}"
                                TextElement.Foreground="{TemplateBinding Foreground}" />

                            <!--  Keyboard shortcut text  -->
                            <TextBlock
                                x:Name="InputGestureText"
                                Grid.Column="3"
                                Margin="16,0,4,0"
                                VerticalAlignment="Center"
                                FontFamily="{TemplateBinding FontFamily}"
                                FontSize="12"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Text="{TemplateBinding InputGestureText}" />

                            <!--  Submenu chevron arrow (hidden by default; shown for SubmenuHeader)  -->
                            <TextBlock
                                x:Name="Arrow"
                                Grid.Column="4"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="12"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Text="&#xE76C;"
                                Visibility="Collapsed" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!--
                            Submenu open: slide SubMenuBorder in from X=-8 → 0 (167ms, ControlFastOutSlowIn).
                            Authority: .NET 10 WPF MenuItem.xaml IsSubmenuOpen EnterActions pattern.
                        -->
                        <Trigger Property="IsSubmenuOpen" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SubMenuTranslate" Storyboard.TargetProperty="X">
                                            <SplineDoubleKeyFrame
                                                KeySpline="0.8,0,0,1"
                                                KeyTime="0:0:0.167"
                                                Value="0" />
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                        </Trigger>
                        <!--  Hover  -->
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                        </Trigger>
                        <!--  Pressed  -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                        </Trigger>
                        <!--  Disabled  -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
                        </Trigger>
                        <!--  Submenu-header: show the chevron arrow (popup already Placement=Right)  -->
                        <Trigger Property="Role" Value="SubmenuHeader">
                            <Setter TargetName="Arrow" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <!--
                            TopLevelHeader: item is a direct child of Menu (horizontal bar).
                            Popup must open BELOW the item, not to the right.
                            Authority: WPF Menu role model - TopLevelHeader owns a dropdown.
                        -->
                        <Trigger Property="Role" Value="TopLevelHeader">
                            <Setter TargetName="PART_Popup" Property="Placement" Value="Bottom" />
                        </Trigger>
                        <!--  Show checkmark when checked and no custom icon  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition Property="Icon" Value="{x:Null}" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                        </MultiTrigger>
                        <!--  Custom icon present: show ContentPresenter, hide checkmark slot  -->
                        <DataTrigger Binding="{Binding Icon, RelativeSource={RelativeSource Self}, Converter={x:Static controls:FluenceWindow.IsNotNullConverter}}" Value="True">
                            <Setter TargetName="Icon" Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <!--  ═══════════════════════════════════════════════════════════  -->
    <!--  Separator  -->
    <!--  ═══════════════════════════════════════════════════════════  -->
    <Style TargetType="{x:Type Separator}">
        <Setter Property="Background" Value="{DynamicResource DividerStrokeColorDefaultBrush}" />
        <Setter Property="Height" Value="1" />
        <Setter Property="Margin" Value="4,2" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Separator}">
                    <Border
                        Height="{TemplateBinding Height}"
                        Margin="{TemplateBinding Margin}"
                        Background="{TemplateBinding Background}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
