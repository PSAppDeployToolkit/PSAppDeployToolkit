    <!--  Caption button style (minimize, maximize, restore)  -->
    <Style x:Key="WindowButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Grid x:Name="RootGrid" Background="{TemplateBinding Background}">
                        <ContentPresenter
                            x:Name="contentPresenter"
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            RecognizesAccessKey="True" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=controls:FluenceWindow}, Path=IsActive}" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
                        </DataTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="RootGrid" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="RootGrid" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="false">
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
                            <Setter TargetName="contentPresenter" Property="Opacity" Value=".5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Width" Value="46" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
    </Style>

    <!--  Close button style - hover/pressed colors driven by caption-specific tokens.  -->
    <Style x:Key="WindowCloseButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Grid x:Name="RootGrid" Background="{TemplateBinding Background}">
                        <ContentPresenter
                            x:Name="contentPresenter"
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            RecognizesAccessKey="True" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=controls:FluenceWindow}, Path=IsActive}" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
                        </DataTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="RootGrid" Property="Background" Value="{DynamicResource WindowCloseButtonBackgroundPointerOverBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource WindowCloseButtonForegroundPointerOverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="RootGrid" Property="Background" Value="{DynamicResource WindowCloseButtonBackgroundPressedBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource WindowCloseButtonForegroundPointerOverBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="false">
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
                            <Setter TargetName="contentPresenter" Property="Opacity" Value=".5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Width" Value="46" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
    </Style>

    <!--  BooleanToVisibilityConverter for ShowIcon/ShowTitle bindings  -->
    <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

    <Style TargetType="{x:Type controls:FluenceWindow}">
        <Setter Property="Background" Value="{DynamicResource ApplicationBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultSolidBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="FontFamily" Value="{DynamicResource FluentFontFamily}" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <!--
            RenderOptions.ClearTypeHint is intentionally left at the WPF default (Auto). Forcing
            Enabled at the window root forces ClearType subpixel rendering even over translucent
            surfaces (Mica / Acrylic backdrops, the AccentFillBackdrop layer, etc.) where ClearType
            cannot blend correctly against the DWM-composited result and falls back to a degraded
            grayscale anti-aliasing that reads as "soft / fuzzy" at body and caption sizes. The
            WPF default lets the renderer pick per-surface: ClearType on opaque, grayscale on
            translucent. .NET 10 WPF Fluent theme also leaves this at the default.
        -->
        <Setter Property="ResizeMode" Value="CanResize" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:FluenceWindow}">
                    <Border
                        x:Name="WindowBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{DynamicResource OverlayCornerRadius}">
                        <Grid Margin="{TemplateBinding MarginMaximized}">
                            <Grid.RowDefinitions>
                                <RowDefinition x:Name="TitleBarRow" Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!--
                                Title bar region.
                                Panel.ZIndex=1 keeps the caption-button strip above client content
                                when ExtendsContentIntoTitleBar=true. Without this, client content
                                renders on top in document order and swallows min / max / close
                                clicks even though the hit-test for NC buttons returns 0 correctly (WI-1 F4).
                            -->
                            <Grid
                                x:Name="TitleBarGrid"
                                Grid.Row="0"
                                Height="{TemplateBinding TitleBarHeight}"
                                Panel.ZIndex="1"
                                Background="Transparent">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!--  Icon  -->
                                <Image
                                    x:Name="WindowIcon"
                                    Grid.Column="0"
                                    Width="20"
                                    Height="20"
                                    Margin="16,0,0,0"
                                    VerticalAlignment="Center"
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    Source="{TemplateBinding Icon}"
                                    Visibility="Hidden" />

                                <!--  Title text  -->
                                <TextBlock
                                    x:Name="TitleText"
                                    Grid.Column="1"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    Foreground="{TemplateBinding Foreground}"
                                    Style="{DynamicResource CaptionTextBlockStyle}"
                                    Text="{TemplateBinding Title}" />

                                <!--  Custom title bar content area  -->
                                <ContentPresenter
                                    x:Name="TitleBarContent"
                                    Grid.Column="2"
                                    Margin="0,0,0,0"
                                    VerticalAlignment="Center"
                                    Panel.ZIndex="1"
                                    Content="{TemplateBinding TitleBar}" />

                                <!--  Caption buttons  -->
                                <Grid
                                    x:Name="CaptionButtonPanel"
                                    Grid.Column="3"
                                    Width="138"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Stretch"
                                    Panel.ZIndex="2"
                                    WindowChrome.IsHitTestVisibleInChrome="True">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="46" />
                                        <ColumnDefinition Width="46" />
                                        <ColumnDefinition Width="46" />
                                    </Grid.ColumnDefinitions>
                                    <Button
                                        x:Name="PART_MinimizeButton"
                                        Grid.Column="0"
                                        AutomationProperties.Name="Minimize"
                                        Command="{x:Static SystemCommands.MinimizeWindowCommand}"
                                        Style="{StaticResource WindowButtonStyle}"
                                        ToolTip="Minimize">
                                        <Path
                                            Width="10"
                                            Height="10"
                                            Data="{StaticResource ChromeMinimize11}"
                                            Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                            Stretch="Uniform" />
                                    </Button>
                                    <Button
                                        x:Name="PART_MaximizeButton"
                                        Grid.Column="1"
                                        AutomationProperties.Name="Maximize"
                                        Command="{x:Static SystemCommands.MaximizeWindowCommand}"
                                        Style="{StaticResource WindowButtonStyle}"
                                        ToolTip="Maximize">
                                        <Path
                                            Width="10"
                                            Height="10"
                                            Data="{StaticResource ChromeMaximize11}"
                                            Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                            Stretch="Uniform" />
                                    </Button>
                                    <Button
                                        x:Name="PART_RestoreButton"
                                        Grid.Column="1"
                                        AutomationProperties.Name="Restore"
                                        Command="{x:Static SystemCommands.RestoreWindowCommand}"
                                        Style="{StaticResource WindowButtonStyle}"
                                        ToolTip="Restore"
                                        Visibility="Collapsed">
                                        <Path
                                            Width="10"
                                            Height="10"
                                            Data="{StaticResource ChromeRestore11}"
                                            Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                            Stretch="Uniform" />
                                    </Button>
                                    <Button
                                        x:Name="PART_CloseButton"
                                        Grid.Column="2"
                                        AutomationProperties.Name="Close"
                                        Command="{x:Static SystemCommands.CloseWindowCommand}"
                                        Style="{StaticResource WindowCloseButtonStyle}"
                                        ToolTip="Close">
                                        <Path
                                            Width="10"
                                            Height="10"
                                            Data="{StaticResource ChromeClose11}"
                                            Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                            Stretch="Uniform" />
                                    </Button>
                                </Grid>
                            </Grid>

                            <!--  Content area: normally in Row 1, overlaps Row 0 when extended  -->
                            <AdornerDecorator x:Name="ContentArea" Grid.Row="1">
                                <ContentPresenter />
                            </AdornerDecorator>

                            <!--
                                Modal dialog overlay host. Spans the whole window (title bar in
                                Row 0 and content in Row 1) above all chrome so a ContentDialog
                                can dim and block the entire window, title-bar content included,
                                while open. Empty and inert (no Background, so hit-testing passes
                                through) until a dialog is shown.
                            -->
                            <Grid
                                x:Name="PART_DialogOverlayHost"
                                Grid.Row="0"
                                Grid.RowSpan="2"
                                Panel.ZIndex="10" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!--  Maximized: remove corner radius and border  -->
                        <Trigger Property="WindowState" Value="Maximized">
                            <Setter TargetName="WindowBorder" Property="BorderThickness" Value="0" />
                            <Setter TargetName="WindowBorder" Property="CornerRadius" Value="0" />
                        </Trigger>

                        <!--  Show icon when set and ShowIcon is true  -->
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Icon, RelativeSource={RelativeSource Self}, Converter={x:Static controls:FluenceWindow.IsNotNullConverter}}" Value="True" />
                                <Condition Binding="{Binding ShowIcon, RelativeSource={RelativeSource Self}}" Value="True" />
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="WindowIcon" Property="Visibility" Value="Visible" />
                        </MultiDataTrigger>

                        <Trigger Property="ShowIcon" Value="False">
                            <Setter TargetName="WindowIcon" Property="Visibility" Value="Hidden" />
                        </Trigger>

                        <Trigger Property="ShowTitle" Value="False">
                            <Setter TargetName="TitleText" Property="Visibility" Value="Hidden" />
                        </Trigger>

                        <DataTrigger Binding="{Binding TitleBar, RelativeSource={RelativeSource Self}, Converter={x:Static controls:FluenceWindow.IsNotNullConverter}}" Value="True">
                            <Setter TargetName="TitleBarContent" Property="Grid.Column" Value="0" />
                            <Setter TargetName="TitleBarContent" Property="Grid.ColumnSpan" Value="4" />
                            <Setter TargetName="WindowIcon" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="TitleText" Property="Visibility" Value="Collapsed" />
                        </DataTrigger>

                        <!--  Inactive window: dim title text  -->
                        <Trigger Property="IsActive" Value="False">
                            <Setter TargetName="TitleText" Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
                        </Trigger>

                        <!--
                            ExtendsContentIntoTitleBar: content fills entire window, title bar overlays.
                            Hide WindowIcon and TitleText - the app is responsible for branding in its own TitleBar content.
                        -->
                        <Trigger Property="ExtendsContentIntoTitleBar" Value="True">
                            <Setter TargetName="TitleBarContent" Property="Grid.Column" Value="0" />
                            <Setter TargetName="TitleBarContent" Property="Grid.ColumnSpan" Value="4" />
                            <Setter TargetName="ContentArea" Property="Grid.Row" Value="0" />
                            <Setter TargetName="ContentArea" Property="Grid.RowSpan" Value="2" />
                            <Setter TargetName="WindowIcon" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="TitleText" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

</ResourceDictionary>
