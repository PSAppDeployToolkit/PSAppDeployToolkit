<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Fluence.Wpf.Controls">

    <!--
        Fluent RatingControl style.
        Authority: WinUI 3 RatingControl_themeresources.xaml + RatingControl.xaml.
        Star glyphs: Segoe Fluent Icons U+E734 (StarEmpty) / U+E735 (StarFilled).
        Filled stars:  AccentFillColorDefaultBrush.
        Empty stars:   TextFillColorSecondaryBrush.
        Disabled:      TextFillColorDisabledBrush.
        Hover preview: AccentFillColorDefaultBrush (all stars up to hovered index).
        PART_StarsPanel: code-generated star TextBlocks, updated by RefreshStars().
        PART_Caption: optional caption TextBlock, Collapsed when Caption is empty.
    -->
    <Style TargetType="{x:Type controls:RatingControl}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Cursor" Value="Arrow" />
        <Setter Property="FocusVisualStyle" Value="{DynamicResource DefaultControlFocusVisualStyle}" />
        <Setter Property="FontFamily" Value="{DynamicResource FluentFontFamily}" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RatingControl}">
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                        <!--  Stars are generated in code via BuildAndRefreshStars() in OnApplyTemplate.  -->
                        <StackPanel
                            x:Name="PART_StarsPanel"
                            VerticalAlignment="Center"
                            Orientation="Horizontal" />
                        <!--  Caption text - Collapsed when Caption is empty.  -->
                        <TextBlock
                            x:Name="PART_Caption"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Visibility="Collapsed" />
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

</ResourceDictionary>
