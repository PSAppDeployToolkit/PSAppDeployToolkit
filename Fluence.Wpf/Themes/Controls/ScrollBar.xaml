<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Fluence.Wpf.Controls"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <sys:Double x:Key="ScrollBarSize">8</sys:Double>
    <sys:Double x:Key="ScrollBarCompactThumbSize">6</sys:Double>
    <sys:Double x:Key="ScrollBarButtonArrowIconFontSize">8</sys:Double>
    <Thickness x:Key="ScrollViewerScrollBarMargin">1</Thickness>
    <SolidColorBrush x:Key="ScrollBarTrackFillBrush" Color="{DynamicResource AcrylicBackgroundFillColorDefault}" />

    <Style x:Key="ScrollBarTrackButtonStyle" TargetType="{x:Type RepeatButton}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Border Background="{TemplateBinding Background}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <Style x:Key="ScrollBarLineButtonStyle" TargetType="{x:Type RepeatButton}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Grid Background="{TemplateBinding Background}">
                        <TextBlock
                            x:Name="ArrowGlyph"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Segoe Fluent Icons"
                            FontSize="{StaticResource ScrollBarButtonArrowIconFontSize}"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            RenderTransformOrigin="0.5,0.5"
                            Text="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}">
                            <TextBlock.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                            <Setter TargetName="ArrowGlyph" Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="{DynamicResource ControlStrongFillColorDefaultBrush}" />
                            <Setter TargetName="ArrowGlyph" Property="Foreground" Value="{DynamicResource TextFillColorInverseBrush}" />
                            <Setter TargetName="ArrowGlyph" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.875" ScaleY="0.875" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ArrowGlyph" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <Style x:Key="ScrollBarThumbStyle" TargetType="{x:Type Thumb}">
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Grid>
                        <Border
                            x:Name="ThumbBorder"
                            Margin="2"
                            Background="{DynamicResource ControlStrongFillColorDefaultBrush}"
                            CornerRadius="4"
                            Opacity="0.72" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Opacity" Value="0.92" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Margin" Value="1" />
                            <Setter TargetName="ThumbBorder" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ThumbBorder" Property="Opacity" Value="0.35" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <!--
        VerticalScrollBarTemplate
        VSM groups:
        CommonStates       – Normal / MouseOver / Disabled
        ScrollingIndicatorStates – MouseIndicator / TouchIndicator / NoIndicator
        State storyboards use DiscreteDoubleKeyFrame (KeyTime="0") so GoToState with
        useTransitions=false applies the final value instantly (test-friendly).
        Smooth runtime animation lives in VisualTransition storyboards.
        ControlTemplate.Triggers are kept for direct hover expansion at runtime
        (ScrollBar does not call GoToState for ScrollingIndicatorStates itself).
        Easing upgraded from CubicEase to SplineDoubleKeyFrame (KeySpline="0.8,0,0,1", WinUI ControlFastOutSlowIn).
    -->
    <ControlTemplate x:Key="VerticalScrollBarTemplate" TargetType="{x:Type ScrollBar}">
        <Grid
            x:Name="Root"
            Width="{StaticResource ScrollBarCompactThumbSize}"
            HorizontalAlignment="Right"
            Background="Transparent">
            <Border
                x:Name="TrackBackground"
                Margin="0"
                Background="{DynamicResource ScrollBarTrackFillBrush}"
                CornerRadius="3"
                Opacity="0" />
            <Track
                x:Name="PART_Track"
                Focusable="False"
                IsDirectionReversed="True"
                Maximum="{TemplateBinding Maximum}"
                Minimum="{TemplateBinding Minimum}"
                ViewportSize="{TemplateBinding ViewportSize}"
                Value="{TemplateBinding Value}">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageUpCommand" Style="{StaticResource ScrollBarTrackButtonStyle}" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageDownCommand" Style="{StaticResource ScrollBarTrackButtonStyle}" />
                </Track.IncreaseRepeatButton>
            </Track>
            <RepeatButton
                x:Name="DecreaseButton"
                Height="{StaticResource ScrollBarSize}"
                VerticalAlignment="Top"
                Panel.ZIndex="2"
                Command="ScrollBar.LineUpCommand"
                Content="&#xE70E;"
                Opacity="0"
                Style="{StaticResource ScrollBarLineButtonStyle}" />
            <RepeatButton
                x:Name="IncreaseButton"
                Height="{StaticResource ScrollBarSize}"
                VerticalAlignment="Bottom"
                Panel.ZIndex="2"
                Command="ScrollBar.LineDownCommand"
                Content="&#xE70D;"
                Opacity="0"
                Style="{StaticResource ScrollBarLineButtonStyle}" />
            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="MouseOver" />
                    <VisualState x:Name="Disabled">
                        <Storyboard>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity">
                                <DiscreteDoubleKeyFrame KeyTime="0" Value="0.45" />
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>
                    </VisualState>
                </VisualStateGroup>
                <VisualStateGroup x:Name="ScrollingIndicatorStates">
                    <VisualStateGroup.Transitions>
                        <VisualTransition From="NoIndicator" To="MouseIndicator">
                            <Storyboard>
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Width">
                                    <SplineDoubleKeyFrame
                                        KeySpline="0.8,0,0,1"
                                        KeyTime="0:0:0.12"
                                        Value="{StaticResource ScrollBarSize}" />
                                </DoubleAnimationUsingKeyFrames>
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TrackBackground" Storyboard.TargetProperty="Opacity">
                                    <SplineDoubleKeyFrame
                                        KeySpline="0.8,0,0,1"
                                        KeyTime="0:0:0.12"
                                        Value="1" />
                                </DoubleAnimationUsingKeyFrames>
                            </Storyboard>
                        </VisualTransition>
                        <VisualTransition From="TouchIndicator" To="MouseIndicator">
                            <Storyboard>
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Width">
                                    <SplineDoubleKeyFrame
                                        KeySpline="0.8,0,0,1"
                                        KeyTime="0:0:0.12"
                                        Value="{StaticResource ScrollBarSize}" />
                                </DoubleAnimationUsingKeyFrames>
                            </Storyboard>
                        </VisualTransition>
                        <VisualTransition From="MouseIndicator" To="NoIndicator">
                            <Storyboard>
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Width">
                                    <SplineDoubleKeyFrame
                                        KeySpline="0.8,0,0,1"
                                        KeyTime="0:0:0.15"
                                        Value="{StaticResource ScrollBarCompactThumbSize}" />
                                </DoubleAnimationUsingKeyFrames>
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TrackBackground" Storyboard.TargetProperty="Opacity">
                                    <SplineDoubleKeyFrame
                                        KeySpline="0.8,0,0,1"
                                        KeyTime="0:0:0.15"
                                        Value="0" />
                                </DoubleAnimationUsingKeyFrames>
                            </Storyboard>
                        </VisualTransition>
                        <VisualTransition From="TouchIndicator" To="NoIndicator">
                            <Storyboard>
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Width">
                                    <SplineDoubleKeyFrame
                                        KeySpline="0.8,0,0,1"
                                        KeyTime="0:0:0.15"
                                        Value="{StaticResource ScrollBarCompactThumbSize}" />
                                </DoubleAnimationUsingKeyFrames>
                            </Storyboard>
                        </VisualTransition>
                    </VisualStateGroup.Transitions>
                    <VisualState x:Name="MouseIndicator">
                        <Storyboard>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Width">
                                <DiscreteDoubleKeyFrame KeyTime="0" Value="{StaticResource ScrollBarSize}" />
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TrackBackground" Storyboard.TargetProperty="Opacity">
                                <DiscreteDoubleKeyFrame KeyTime="0" Value="1" />
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="DecreaseButton" Storyboard.TargetProperty="Opacity">
                                <DiscreteDoubleKeyFrame KeyTime="0" Value="1" />
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="IncreaseButton" Storyboard.TargetProperty="Opacity">
                                <DiscreteDoubleKeyFrame KeyTime="0" Value="1" />
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>
                    </VisualState>
                    <VisualState x:Name="TouchIndicator">
                        <Storyboard>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Width">
                                <DiscreteDoubleKeyFrame KeyTime="0" Value="{StaticResource ScrollBarSize}" />
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>
                    </VisualState>
                    <VisualState x:Name="NoIndicator">
                        <Storyboard>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Width">
                                <DiscreteDoubleKeyFrame KeyTime="0" Value="{StaticResource ScrollBarCompactThumbSize}" />
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TrackBackground" Storyboard.TargetProperty="Opacity">
                                <DiscreteDoubleKeyFrame KeyTime="0" Value="0" />
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="DecreaseButton" Storyboard.TargetProperty="Opacity">
                                <DiscreteDoubleKeyFrame KeyTime="0" Value="0" />
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="IncreaseButton" Storyboard.TargetProperty="Opacity">
                                <DiscreteDoubleKeyFrame KeyTime="0" Value="0" />
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="TrackBackground" Property="Opacity" Value="1" />
                <Setter TargetName="DecreaseButton" Property="Opacity" Value="1" />
                <Setter TargetName="IncreaseButton" Property="Opacity" Value="1" />
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Width">
                                <SplineDoubleKeyFrame
                                    KeySpline="0.8,0,0,1"
                                    KeyTime="0:0:0.12"
                                    Value="{StaticResource ScrollBarSize}" />
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Width">
                                <SplineDoubleKeyFrame
                                    KeySpline="0.8,0,0,1"
                                    KeyTime="0:0:0.15"
                                    Value="{StaticResource ScrollBarCompactThumbSize}" />
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!--
        HorizontalScrollBarTemplate - mirrors VerticalScrollBarTemplate with Width/Height swapped.
    -->
    <ControlTemplate x:Key="HorizontalScrollBarTemplate" TargetType="{x:Type ScrollBar}">
        <Grid
            x:Name="Root"
            Height="{StaticResource ScrollBarCompactThumbSize}"
            VerticalAlignment="Bottom"
            Background="Transparent">
            <Border
                x:Name="TrackBackground"
                Margin="0"
                Background="{DynamicResource ScrollBarTrackFillBrush}"
                CornerRadius="3"
                Opacity="0" />
            <Track
                x:Name="PART_Track"
                Focusable="False"
                Maximum="{TemplateBinding Maximum}"
                Minimum="{TemplateBinding Minimum}"
                ViewportSize="{TemplateBinding ViewportSize}"
                Value="{TemplateBinding Value}">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageLeftCommand" Style="{StaticResource ScrollBarTrackButtonStyle}" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageRightCommand" Style="{StaticResource ScrollBarTrackButtonStyle}" />
                </Track.IncreaseRepeatButton>
            </Track>
            <RepeatButton
                x:Name="DecreaseButton"
                Width="{StaticResource ScrollBarSize}"
                HorizontalAlignment="Left"
                Panel.ZIndex="2"
                Command="ScrollBar.LineLeftCommand"
                Content="&#xE76B;"
                Opacity="0"
                Style="{StaticResource ScrollBarLineButtonStyle}" />
            <RepeatButton
                x:Name="IncreaseButton"
                Width="{StaticResource ScrollBarSize}"
                HorizontalAlignment="Right"
                Panel.ZIndex="2"
                Command="ScrollBar.LineRightCommand"
                Content="&#xE76C;"
                Opacity="0"
                Style="{StaticResource ScrollBarLineButtonStyle}" />
            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="MouseOver" />
                    <VisualState x:Name="Disabled">
                        <Storyboard>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity">
                                <DiscreteDoubleKeyFrame KeyTime="0" Value="0.45" />
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>
                    </VisualState>
                </VisualStateGroup>
                <VisualStateGroup x:Name="ScrollingIndicatorStates">
                    <VisualStateGroup.Transitions>
                        <VisualTransition From="NoIndicator" To="MouseIndicator">
                            <Storyboard>
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Height">
                                    <SplineDoubleKeyFrame
                                        KeySpline="0.8,0,0,1"
                                        KeyTime="0:0:0.12"
                                        Value="{StaticResource ScrollBarSize}" />
                                </DoubleAnimationUsingKeyFrames>
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TrackBackground" Storyboard.TargetProperty="Opacity">
                                    <SplineDoubleKeyFrame
                                        KeySpline="0.8,0,0,1"
                                        KeyTime="0:0:0.12"
                                        Value="1" />
                                </DoubleAnimationUsingKeyFrames>
                            </Storyboard>
                        </VisualTransition>
                        <VisualTransition From="TouchIndicator" To="MouseIndicator">
                            <Storyboard>
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Height">
                                    <SplineDoubleKeyFrame
                                        KeySpline="0.8,0,0,1"
                                        KeyTime="0:0:0.12"
                                        Value="{StaticResource ScrollBarSize}" />
                                </DoubleAnimationUsingKeyFrames>
                            </Storyboard>
                        </VisualTransition>
                        <VisualTransition From="MouseIndicator" To="NoIndicator">
                            <Storyboard>
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Height">
                                    <SplineDoubleKeyFrame
                                        KeySpline="0.8,0,0,1"
                                        KeyTime="0:0:0.15"
                                        Value="{StaticResource ScrollBarCompactThumbSize}" />
                                </DoubleAnimationUsingKeyFrames>
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TrackBackground" Storyboard.TargetProperty="Opacity">
                                    <SplineDoubleKeyFrame
                                        KeySpline="0.8,0,0,1"
                                        KeyTime="0:0:0.15"
                                        Value="0" />
                                </DoubleAnimationUsingKeyFrames>
                            </Storyboard>
                        </VisualTransition>
                        <VisualTransition From="TouchIndicator" To="NoIndicator">
                            <Storyboard>
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Height">
                                    <SplineDoubleKeyFrame
                                        KeySpline="0.8,0,0,1"
                                        KeyTime="0:0:0.15"
                                        Value="{StaticResource ScrollBarCompactThumbSize}" />
                                </DoubleAnimationUsingKeyFrames>
                            </Storyboard>
                        </VisualTransition>
                    </VisualStateGroup.Transitions>
                    <VisualState x:Name="MouseIndicator">
                        <Storyboard>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Height">
                                <DiscreteDoubleKeyFrame KeyTime="0" Value="{StaticResource ScrollBarSize}" />
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TrackBackground" Storyboard.TargetProperty="Opacity">
                                <DiscreteDoubleKeyFrame KeyTime="0" Value="1" />
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="DecreaseButton" Storyboard.TargetProperty="Opacity">
                                <DiscreteDoubleKeyFrame KeyTime="0" Value="1" />
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="IncreaseButton" Storyboard.TargetProperty="Opacity">
                                <DiscreteDoubleKeyFrame KeyTime="0" Value="1" />
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>
                    </VisualState>
                    <VisualState x:Name="TouchIndicator">
                        <Storyboard>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Height">
                                <DiscreteDoubleKeyFrame KeyTime="0" Value="{StaticResource ScrollBarSize}" />
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>
                    </VisualState>
                    <VisualState x:Name="NoIndicator">
                        <Storyboard>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Height">
                                <DiscreteDoubleKeyFrame KeyTime="0" Value="{StaticResource ScrollBarCompactThumbSize}" />
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TrackBackground" Storyboard.TargetProperty="Opacity">
                                <DiscreteDoubleKeyFrame KeyTime="0" Value="0" />
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="DecreaseButton" Storyboard.TargetProperty="Opacity">
                                <DiscreteDoubleKeyFrame KeyTime="0" Value="0" />
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="IncreaseButton" Storyboard.TargetProperty="Opacity">
                                <DiscreteDoubleKeyFrame KeyTime="0" Value="0" />
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="TrackBackground" Property="Opacity" Value="1" />
                <Setter TargetName="DecreaseButton" Property="Opacity" Value="1" />
                <Setter TargetName="IncreaseButton" Property="Opacity" Value="1" />
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Height">
                                <SplineDoubleKeyFrame
                                    KeySpline="0.8,0,0,1"
                                    KeyTime="0:0:0.12"
                                    Value="{StaticResource ScrollBarSize}" />
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Height">
                                <SplineDoubleKeyFrame
                                    KeySpline="0.8,0,0,1"
                                    KeyTime="0:0:0.15"
                                    Value="{StaticResource ScrollBarCompactThumbSize}" />
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="VerticalScrollBarStyle" TargetType="{x:Type ScrollBar}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="MinWidth" Value="{StaticResource ScrollBarSize}" />
        <Setter Property="Orientation" Value="Vertical" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template" Value="{StaticResource VerticalScrollBarTemplate}" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Width" Value="{StaticResource ScrollBarSize}" />
    </Style>

    <Style x:Key="HorizontalScrollBarStyle" TargetType="{x:Type ScrollBar}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Height" Value="{StaticResource ScrollBarSize}" />
        <Setter Property="MinHeight" Value="{StaticResource ScrollBarSize}" />
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template" Value="{StaticResource HorizontalScrollBarTemplate}" />
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <Style x:Key="ScrollViewerStyle" TargetType="{x:Type ScrollViewer}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ScrollViewer}">
                    <Border
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="8,0,0,0">
                        <Grid>
                            <ScrollContentPresenter
                                x:Name="PART_ScrollContentPresenter"
                                Margin="{TemplateBinding Padding}"
                                CanContentScroll="{TemplateBinding CanContentScroll}"
                                CanHorizontallyScroll="False"
                                CanVerticallyScroll="False"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}" />
                            <ScrollBar
                                x:Name="PART_VerticalScrollBar"
                                Margin="{StaticResource ScrollViewerScrollBarMargin}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Stretch"
                                Panel.ZIndex="1"
                                Maximum="{TemplateBinding ScrollableHeight}"
                                Minimum="0"
                                Style="{StaticResource VerticalScrollBarStyle}"
                                ViewportSize="{TemplateBinding ViewportHeight}"
                                Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                Value="{TemplateBinding VerticalOffset}" />
                            <ScrollBar
                                x:Name="PART_HorizontalScrollBar"
                                Margin="{StaticResource ScrollViewerScrollBarMargin}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Bottom"
                                Panel.ZIndex="1"
                                Maximum="{TemplateBinding ScrollableWidth}"
                                Minimum="0"
                                Style="{StaticResource HorizontalScrollBarStyle}"
                                ViewportSize="{TemplateBinding ViewportWidth}"
                                Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"
                                Value="{TemplateBinding HorizontalOffset}" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <Style BasedOn="{StaticResource ScrollViewerStyle}" TargetType="{x:Type controls:SmoothScrollViewer}" />

</ResourceDictionary>
