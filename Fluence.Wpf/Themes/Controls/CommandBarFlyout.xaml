<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Fluence.Wpf.Controls">

    <!--
        Fluent Design CommandBarFlyout presenter + AppBarButton styles.
        Authority: WinUI 3 CommandBarFlyout_themeresources.xaml (flyout surface, subtle
        backplates) translated to the in-tree flyout idiom:
        SolidBackgroundFillColorTertiaryBrush + SurfaceStrokeColorFlyoutBrush +
        OverlayCornerRadius (see FlyoutPresenter.xaml / ContextMenu.xaml).
        No DropShadowEffect on the Border - WPF bitmap effects on a Border with CornerRadius
        produce artifacts in a Popup (see DropDownButton.xaml).
    -->

    <!--
        Compact (primary bar) AppBarButton: 40x40 hit target, centered icon, Label surfaced
        as a tooltip. Hover/press backplates use the subtle fills like MenuItem.
    -->
    <Style TargetType="{x:Type controls:AppBarButton}">
        <Setter Property="Background" Value="{DynamicResource SubtleFillColorTransparentBrush}" />
        <Setter Property="FocusVisualStyle" Value="{DynamicResource DefaultControlFocusVisualStyle}" />
        <Setter Property="FontFamily" Value="{DynamicResource FluentFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="MinWidth" Value="40" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:AppBarButton}">
                    <Border
                        x:Name="Backplate"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{DynamicResource ControlCornerRadius}"
                        RenderTransformOrigin="0.5,0.5"
                        UseLayoutRounding="True">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
                        </Border.RenderTransform>
                        <!--  Icon normalized into a 16px-high Viewbox per WinUI ContentViewbox.  -->
                        <Viewbox
                            Height="16"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <ContentPresenter
                                x:Name="IconPresenter"
                                Content="{TemplateBinding Icon}"
                                TextElement.FontFamily="{TemplateBinding FontFamily}"
                                TextElement.FontSize="{TemplateBinding FontSize}"
                                TextElement.Foreground="{TemplateBinding Foreground}">
                                <ContentPresenter.Resources>
                                    <!--  Icon follows the control text (SplitButton precedent): the scoped implicit style outranks the FontIcon theme-style Foreground; a consumer's local Foreground still wins.  -->
                                    <Style TargetType="{x:Type controls:FontIcon}">
                                        <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type controls:AppBarButton}}}" />
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                        </Viewbox>
                    </Border>
                    <!--  Press scale storyboards mirror Button.xaml (0.98 over 100ms on the 0.8,0,0,1 ControlFastOutSlowIn spline).  -->
                    <ControlTemplate.Resources>
                        <Storyboard x:Key="PressedScaleStoryboard">
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleX">
                                <SplineDoubleKeyFrame
                                    KeySpline="0.8,0,0,1"
                                    KeyTime="0:0:0.1"
                                    Value="0.98" />
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleY">
                                <SplineDoubleKeyFrame
                                    KeySpline="0.8,0,0,1"
                                    KeyTime="0:0:0.1"
                                    Value="0.98" />
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>
                        <Storyboard x:Key="ReleasedScaleStoryboard">
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleX">
                                <SplineDoubleKeyFrame
                                    KeySpline="0.8,0,0,1"
                                    KeyTime="0:0:0.1"
                                    Value="1" />
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleY">
                                <SplineDoubleKeyFrame
                                    KeySpline="0.8,0,0,1"
                                    KeyTime="0:0:0.1"
                                    Value="1" />
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>
                    </ControlTemplate.Resources>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Backplate" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Backplate" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                            <Trigger.EnterActions>
                                <BeginStoryboard Storyboard="{StaticResource PressedScaleStoryboard}" />
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard Storyboard="{StaticResource ReleasedScaleStoryboard}" />
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ToolTip" Value="{Binding Label, RelativeSource={RelativeSource Self}}" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Style.Triggers>
            <!--  No tooltip balloon when there is no label to surface.  -->
            <Trigger Property="Label" Value="">
                <Setter Property="ToolTip" Value="{x:Null}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--
        Overflow (secondary menu) AppBarButton: full-width menu-item-like row with the icon
        and label side by side. Metrics mirror the in-tree MenuItem (ContextMenu.xaml).
        Applied by the presenter via an implicit style in the secondary ItemsControl.
    -->
    <Style x:Key="CommandBarFlyoutSecondaryAppBarButtonStyle" TargetType="{x:Type controls:AppBarButton}">
        <Setter Property="Background" Value="{DynamicResource SubtleFillColorTransparentBrush}" />
        <Setter Property="FocusVisualStyle" Value="{DynamicResource DefaultControlFocusVisualStyle}" />
        <Setter Property="FontFamily" Value="{DynamicResource FluentFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:AppBarButton}">
                    <Border
                        x:Name="Backplate"
                        Margin="2,1"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{DynamicResource ControlCornerRadius}"
                        RenderTransformOrigin="0.5,0.5"
                        UseLayoutRounding="True">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
                        </Border.RenderTransform>
                        <Grid Margin="4,0">
                            <Grid.ColumnDefinitions>
                                <!--  Icon  -->
                                <ColumnDefinition Width="20" />
                                <!--  Gap  -->
                                <ColumnDefinition Width="8" />
                                <!--  Label  -->
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <!--  Icon normalized into a 16px-high Viewbox per WinUI ContentViewbox.  -->
                            <Viewbox
                                Grid.Column="0"
                                Height="16"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                                <ContentPresenter
                                    x:Name="IconPresenter"
                                    Content="{TemplateBinding Icon}"
                                    TextElement.Foreground="{TemplateBinding Foreground}">
                                    <ContentPresenter.Resources>
                                        <!--  Icon follows the control text (SplitButton precedent): the scoped implicit style outranks the FontIcon theme-style Foreground; a consumer's local Foreground still wins.  -->
                                        <Style TargetType="{x:Type controls:FontIcon}">
                                            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type controls:AppBarButton}}}" />
                                        </Style>
                                    </ContentPresenter.Resources>
                                </ContentPresenter>
                            </Viewbox>
                            <TextBlock
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                FontFamily="{TemplateBinding FontFamily}"
                                FontSize="{TemplateBinding FontSize}"
                                Foreground="{TemplateBinding Foreground}"
                                Text="{TemplateBinding Label}" />
                        </Grid>
                    </Border>
                    <!--  Press scale storyboards mirror Button.xaml (0.98 over 100ms on the 0.8,0,0,1 ControlFastOutSlowIn spline).  -->
                    <ControlTemplate.Resources>
                        <Storyboard x:Key="PressedScaleStoryboard">
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleX">
                                <SplineDoubleKeyFrame
                                    KeySpline="0.8,0,0,1"
                                    KeyTime="0:0:0.1"
                                    Value="0.98" />
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleY">
                                <SplineDoubleKeyFrame
                                    KeySpline="0.8,0,0,1"
                                    KeyTime="0:0:0.1"
                                    Value="0.98" />
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>
                        <Storyboard x:Key="ReleasedScaleStoryboard">
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleX">
                                <SplineDoubleKeyFrame
                                    KeySpline="0.8,0,0,1"
                                    KeyTime="0:0:0.1"
                                    Value="1" />
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleY">
                                <SplineDoubleKeyFrame
                                    KeySpline="0.8,0,0,1"
                                    KeyTime="0:0:0.1"
                                    Value="1" />
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>
                    </ControlTemplate.Resources>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Backplate" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Backplate" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                            <Trigger.EnterActions>
                                <BeginStoryboard Storyboard="{StaticResource PressedScaleStoryboard}" />
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard Storyboard="{StaticResource ReleasedScaleStoryboard}" />
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <!--
        CommandBarFlyoutPresenter: one rounded flyout surface containing the horizontal
        primary bar (+ more button) and the collapsible secondary area below it, separated
        by a divider. The presenter sizes to content; the secondary menu keeps the in-tree
        180px flyout menu minimum (ContextMenu.xaml).
    -->
    <Style TargetType="{x:Type controls:CommandBarFlyoutPresenter}">
        <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorTertiaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SurfaceStrokeColorFlyoutBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontFamily" Value="{DynamicResource FluentFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:CommandBarFlyoutPresenter}">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{DynamicResource OverlayCornerRadius}"
                        UseLayoutRounding="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!--  Primary bar  -->
                            <StackPanel
                                Grid.Row="0"
                                Margin="4"
                                Orientation="Horizontal">
                                <ItemsControl x:Name="PART_PrimaryItemsControl" Focusable="False">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                                <controls:AppBarButton
                                    x:Name="PART_MoreButton"
                                    Label="See more"
                                    Visibility="Collapsed">
                                    <controls:AppBarButton.Icon>
                                        <controls:FontIcon
                                            x:Name="MoreButtonIcon"
                                            Glyph="&#xE712;"
                                            RenderTransformOrigin="0.5,0.5">
                                            <controls:FontIcon.RenderTransform>
                                                <RotateTransform x:Name="MoreButtonIconRotation" Angle="0" />
                                            </controls:FontIcon.RenderTransform>
                                        </controls:FontIcon>
                                    </controls:AppBarButton.Icon>
                                </controls:AppBarButton>
                            </StackPanel>

                            <!--  Secondary (overflow) area, toggled by PART_MoreButton via IsExpanded  -->
                            <StackPanel
                                x:Name="PART_SecondaryHost"
                                Grid.Row="1"
                                RenderTransformOrigin="0,0"
                                Visibility="Collapsed">
                                <StackPanel.RenderTransform>
                                    <ScaleTransform x:Name="SecondaryHostScale" ScaleX="1" ScaleY="1" />
                                </StackPanel.RenderTransform>
                                <Border
                                    Height="1"
                                    Margin="4,2"
                                    Background="{DynamicResource DividerStrokeColorDefaultBrush}" />
                                <ItemsControl
                                    x:Name="PART_SecondaryItemsControl"
                                    MinWidth="180"
                                    Margin="2,0,2,2"
                                    Focusable="False">
                                    <ItemsControl.Resources>
                                        <Style BasedOn="{StaticResource CommandBarFlyoutSecondaryAppBarButtonStyle}" TargetType="{x:Type controls:AppBarButton}" />
                                    </ItemsControl.Resources>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!--
                            Overflow expand/collapse over 167ms on the 0.8,0,0,1 spline
                            (Typography.xaml motion tokens ControlFastAnimationDuration +
                            ControlFastOutSlowInKeySpline; storyboard attributes need literal
                            values). The reveal is a top-anchored ScaleY 0 to 1 on the secondary
                            host (RenderTransform keeps the popup at its final size while the
                            content sweeps in, matching the WinUI overflow feel; the in-tree
                            Expander.xaml alternative snaps its height discretely and animates
                            less); the more-button glyph rotates 0 to 180 like the Expander
                            chevron. The exit storyboard holds the host Visible while it scales
                            back to 0 and collapses it fully at the end via the discrete
                            Visibility keyframe (Expander.xaml ObjectAnimationUsingKeyFrames
                            precedent); both storyboards pin Visibility so each replaces the
                            other's held value on re-toggle.
                        -->
                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="PART_SecondaryHost" Property="Visibility" Value="Visible" />
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="PART_SecondaryHost" Storyboard.TargetProperty="Visibility">
                                            <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}" />
                                        </ObjectAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SecondaryHostScale" Storyboard.TargetProperty="ScaleY">
                                            <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                                            <SplineDoubleKeyFrame
                                                KeySpline="0.8,0,0,1"
                                                KeyTime="0:0:0.167"
                                                Value="1" />
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MoreButtonIconRotation" Storyboard.TargetProperty="Angle">
                                            <SplineDoubleKeyFrame
                                                KeySpline="0.8,0,0,1"
                                                KeyTime="0:0:0.167"
                                                Value="180" />
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="PART_SecondaryHost" Storyboard.TargetProperty="Visibility">
                                            <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}" />
                                            <DiscreteObjectKeyFrame KeyTime="0:0:0.167" Value="{x:Static Visibility.Collapsed}" />
                                        </ObjectAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SecondaryHostScale" Storyboard.TargetProperty="ScaleY">
                                            <SplineDoubleKeyFrame
                                                KeySpline="0.8,0,0,1"
                                                KeyTime="0:0:0.167"
                                                Value="0" />
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MoreButtonIconRotation" Storyboard.TargetProperty="Angle">
                                            <SplineDoubleKeyFrame
                                                KeySpline="0.8,0,0,1"
                                                KeyTime="0:0:0.167"
                                                Value="0" />
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

</ResourceDictionary>
