<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Fluence.Wpf.Controls">

    <!--
        WinUI 3 ToggleSplitButton reference:
        https://github.com/microsoft/microsoft-ui-xaml/blob/main/src/controls/dev/SplitButton/SplitButton.xaml
        (the SplitButton style defines the Checked* visual states shared by ToggleSplitButton)
        
        Standalone copy of the SplitButton template (repo convention: one file per control,
        no BasedOn) with a checked block appended after every base trigger so WPF last-wins
        precedence lets the checked visuals override the neutral and Accent-appearance
        states. WinUI's CheckedTouchPressed state is not modeled separately because WPF
        ButtonBase.IsPressed already covers touch and stylus presses.
        
        Bare Property="IsChecked" conditions resolve against the templated parent
        (ToggleSplitButton.IsChecked); the secondary part's nullable IsChecked is always
        scoped with SourceName="PART_SecondaryButton".
    -->
    <Style TargetType="{x:Type controls:ToggleSplitButton}">
        <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="FontFamily" Value="{DynamicResource FluentFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Padding" Value="11,5,11,6" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ToggleSplitButton}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--
                            Row 0: the two-half body.
                            Inner style override: make nested Button / ToggleButton visually
                            invisible - they are behavior-only hit targets. Per-half fills
                            below own the hover / pressed visuals.
                            Focus visuals come from the DefaultControlFocusVisualStyle adorner
                            on each half's hit target, so WPF shows them only for keyboard
                            navigation (Tab), never on mouse click - matching DropDownButton.
                        -->
                        <Grid x:Name="SplitButtonBody" Grid.Row="0">
                            <Grid.Resources>
                                <Style TargetType="{x:Type Button}">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="FocusVisualStyle" Value="{DynamicResource DefaultControlFocusVisualStyle}" />
                                    <Setter Property="FontFamily" Value="{Binding FontFamily, RelativeSource={RelativeSource AncestorType={x:Type controls:ToggleSplitButton}}}" />
                                    <Setter Property="FontSize" Value="{Binding FontSize, RelativeSource={RelativeSource AncestorType={x:Type controls:ToggleSplitButton}}}" />
                                    <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type controls:ToggleSplitButton}}}" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type Button}">
                                                <Border Background="Transparent">
                                                    <ContentPresenter
                                                        Margin="{TemplateBinding Padding}"
                                                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                        RecognizesAccessKey="True"
                                                        TextElement.FontFamily="{TemplateBinding FontFamily}"
                                                        TextElement.FontSize="{TemplateBinding FontSize}"
                                                        TextElement.Foreground="{TemplateBinding Foreground}" />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                                <Style TargetType="{x:Type controls:FontIcon}">
                                    <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type controls:ToggleSplitButton}}}" />
                                </Style>
                            </Grid.Resources>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!--
                                Opaque sub-layer behind PrimaryFill so accent hover/press
                                (Secondary/Tertiary, 0.9/0.8 alpha) composite against a
                                surface-matched solid rather than the translucent card or
                                Mica beneath. Visible when Appearance=Accent or IsChecked.
                            -->
                            <Border
                                x:Name="PrimaryAccentFillBackdrop"
                                Grid.Column="0"
                                Background="{DynamicResource AccentFillBackdropBrush}"
                                CornerRadius="4,0,0,4"
                                Opacity="0" />
                            <!--  Primary-half fill + border (rounded left, flat right, no right-side stroke).  -->
                            <Border
                                x:Name="PrimaryFill"
                                Grid.Column="0"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4,0,0,4" />
                            <Border
                                x:Name="PrimaryStroke"
                                Grid.Column="0"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1,1,0,1"
                                CornerRadius="4,0,0,4"
                                IsHitTestVisible="False" />

                            <!--  Primary hit target. Stays transparent - visuals come from PrimaryFill.  -->
                            <Button
                                x:Name="PART_PrimaryButton"
                                Grid.Column="0"
                                Padding="{TemplateBinding Padding}"
                                HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                IsTabStop="True" />

                            <!--  Divider stroke between halves.  -->
                            <Rectangle
                                x:Name="Divider"
                                Grid.Column="1"
                                Width="1"
                                Fill="{DynamicResource ControlStrokeColorDefaultBrush}" />

                            <!--  Opaque sub-layer behind SecondaryFill - see PrimaryAccentFillBackdrop note above.  -->
                            <Border
                                x:Name="SecondaryAccentFillBackdrop"
                                Grid.Column="2"
                                Background="{DynamicResource AccentFillBackdropBrush}"
                                CornerRadius="0,4,4,0"
                                Opacity="0" />
                            <!--  Secondary-half fill + border (flat left, rounded right, no left-side stroke).  -->
                            <Border
                                x:Name="SecondaryFill"
                                Grid.Column="2"
                                Background="{TemplateBinding Background}"
                                CornerRadius="0,4,4,0" />
                            <Border
                                x:Name="SecondaryStroke"
                                Grid.Column="2"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,1,1,1"
                                CornerRadius="0,4,4,0"
                                IsHitTestVisible="False" />

                            <!--  Secondary hit target (chevron toggles PART_Popup).  -->
                            <ToggleButton
                                x:Name="PART_SecondaryButton"
                                Grid.Column="2"
                                Width="32"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                FocusVisualStyle="{DynamicResource DefaultControlFocusVisualStyle}"
                                IsTabStop="True">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border Background="Transparent">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <controls:FontIcon Glyph="&#xE70D;" IconFontSize="12" />
                            </ToggleButton>
                        </Grid>

                        <!--  Flyout popup (mirror SplitButton).  -->
                        <Popup
                            x:Name="PART_Popup"
                            Grid.Row="1"
                            AllowsTransparency="True"
                            Focusable="False"
                            Placement="Bottom"
                            PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                            PopupAnimation="None">
                            <Border
                                MinWidth="{Binding ActualWidth, ElementName=SplitButtonBody}"
                                Margin="0,4,0,0"
                                Background="{DynamicResource SolidBackgroundFillColorQuarternaryBrush}"
                                BorderBrush="{DynamicResource SurfaceStrokeColorFlyoutBrush}"
                                BorderThickness="1"
                                CornerRadius="{TemplateBinding DropdownCornerRadius}">
                                <!--
                                    No DropShadowEffect: WPF bitmap effects on a Border with CornerRadius
                                    always bleed into the transparent corner nooks, producing darker
                                    squared-off artifacts at the rounded corners regardless of ShadowDepth.
                                    Real WinUI 3 uses DWM-managed compositor shadows (not WPF effects).
                                    The SurfaceStrokeColorFlyoutBrush border + background contrast is
                                    sufficient for visual separation without the rendering artifact.
                                -->
                                <ContentPresenter
                                    x:Name="FlyoutContentPresenter"
                                    Margin="4"
                                    HorizontalAlignment="Stretch"
                                    Content="{TemplateBinding Flyout}"
                                    ContentTemplate="{TemplateBinding FlyoutTemplate}" />
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!--  Primary half hover / press.  -->
                        <Trigger SourceName="PART_PrimaryButton" Property="IsMouseOver" Value="True">
                            <Setter TargetName="PrimaryFill" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                        </Trigger>
                        <Trigger SourceName="PART_PrimaryButton" Property="IsPressed" Value="True">
                            <Setter TargetName="PrimaryFill" Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
                        </Trigger>
                        <!--  Secondary half hover / press (separate from primary so tints are per-half).  -->
                        <Trigger SourceName="PART_SecondaryButton" Property="IsMouseOver" Value="True">
                            <Setter TargetName="SecondaryFill" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                        </Trigger>
                        <Trigger SourceName="PART_SecondaryButton" Property="IsPressed" Value="True">
                            <Setter TargetName="SecondaryFill" Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
                        </Trigger>
                        <Trigger SourceName="PART_SecondaryButton" Property="IsChecked" Value="True">
                            <Setter TargetName="SecondaryFill" Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
                        </Trigger>
                        <!--  Disabled.  -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="PrimaryFill" Property="Background" Value="{DynamicResource ControlFillColorDisabledBrush}" />
                            <Setter TargetName="SecondaryFill" Property="Background" Value="{DynamicResource ControlFillColorDisabledBrush}" />
                            <Setter TargetName="PrimaryStroke" Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
                            <Setter TargetName="SecondaryStroke" Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
                        </Trigger>

                        <!--
                            Accent appearance - divider uses ControlStrokeColorOnAccentSecondaryBrush
                            instead of the default ControlStrokeColorDefaultBrush. All per-half
                            hover / press tints and stroke colours also shift to the accent palette.
                        -->
                        <Trigger Property="Appearance" Value="Accent">
                            <Setter TargetName="PrimaryStroke" Property="BorderBrush" Value="{DynamicResource AccentControlElevationBorderBrush}" />
                            <Setter TargetName="SecondaryStroke" Property="BorderBrush" Value="{DynamicResource AccentControlElevationBorderBrush}" />
                            <Setter TargetName="PrimaryAccentFillBackdrop" Property="Opacity" Value="1" />
                            <Setter TargetName="SecondaryAccentFillBackdrop" Property="Opacity" Value="1" />
                            <Setter TargetName="Divider" Property="Fill" Value="{DynamicResource ControlStrokeColorOnAccentSecondaryBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
                        </Trigger>

                        <!--  Accent + primary hover.  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition SourceName="PART_PrimaryButton" Property="IsMouseOver" Value="True" />
                                <Condition Property="Appearance" Value="Accent" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PrimaryFill" Property="Background" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
                            <Setter TargetName="PrimaryStroke" Property="BorderBrush" Value="{DynamicResource AccentControlElevationBorderBrush}" />
                        </MultiTrigger>

                        <!--  Accent + primary press.  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition SourceName="PART_PrimaryButton" Property="IsPressed" Value="True" />
                                <Condition Property="Appearance" Value="Accent" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PrimaryFill" Property="Background" Value="{DynamicResource AccentFillColorTertiaryBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorSecondaryBrush}" />
                        </MultiTrigger>

                        <!--  Accent + secondary hover.  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition SourceName="PART_SecondaryButton" Property="IsMouseOver" Value="True" />
                                <Condition Property="Appearance" Value="Accent" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="SecondaryFill" Property="Background" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
                            <Setter TargetName="SecondaryStroke" Property="BorderBrush" Value="{DynamicResource AccentControlElevationBorderBrush}" />
                        </MultiTrigger>

                        <!--  Accent + secondary press.  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition SourceName="PART_SecondaryButton" Property="IsPressed" Value="True" />
                                <Condition Property="Appearance" Value="Accent" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="SecondaryFill" Property="Background" Value="{DynamicResource AccentFillColorTertiaryBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorSecondaryBrush}" />
                        </MultiTrigger>

                        <!--  Accent + disabled.  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsEnabled" Value="False" />
                                <Condition Property="Appearance" Value="Accent" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PrimaryFill" Property="Background" Value="{DynamicResource AccentFillColorDisabledBrush}" />
                            <Setter TargetName="SecondaryFill" Property="Background" Value="{DynamicResource AccentFillColorDisabledBrush}" />
                            <Setter TargetName="PrimaryStroke" Property="BorderBrush" Value="{DynamicResource ControlFillColorTransparentBrush}" />
                            <Setter TargetName="SecondaryStroke" Property="BorderBrush" Value="{DynamicResource ControlFillColorTransparentBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorDisabledBrush}" />
                        </MultiTrigger>

                        <!--
                            Checked block (WinUI ToggleSplitButton Checked* states). Appended after
                            every base trigger so checked visuals win over the neutral and
                            Accent-appearance states; CheckedFlyoutOpen and checked+disabled sit
                            last within the block for the same last-wins reason.
                        -->
                        <!--  Checked rest: accent on both halves, checked divider stroke (WinUI Checked).  -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="PrimaryStroke" Property="BorderBrush" Value="{DynamicResource AccentControlElevationBorderBrush}" />
                            <Setter TargetName="SecondaryStroke" Property="BorderBrush" Value="{DynamicResource AccentControlElevationBorderBrush}" />
                            <Setter TargetName="PrimaryAccentFillBackdrop" Property="Opacity" Value="1" />
                            <Setter TargetName="SecondaryAccentFillBackdrop" Property="Opacity" Value="1" />
                            <Setter TargetName="Divider" Property="Fill" Value="{DynamicResource ControlStrokeColorOnAccentTertiaryBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
                        </Trigger>

                        <!--  Checked + primary hover (WinUI CheckedPrimaryPointerOver).  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition SourceName="PART_PrimaryButton" Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PrimaryFill" Property="Background" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
                        </MultiTrigger>

                        <!--  Checked + primary press (WinUI CheckedPrimaryPressed).  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition SourceName="PART_PrimaryButton" Property="IsPressed" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PrimaryFill" Property="Background" Value="{DynamicResource AccentFillColorTertiaryBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorSecondaryBrush}" />
                        </MultiTrigger>

                        <!--  Checked + secondary hover (WinUI CheckedSecondaryPointerOver).  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition SourceName="PART_SecondaryButton" Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="SecondaryFill" Property="Background" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
                        </MultiTrigger>

                        <!--  Checked + secondary press (WinUI CheckedSecondaryPressed).  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition SourceName="PART_SecondaryButton" Property="IsPressed" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="SecondaryFill" Property="Background" Value="{DynamicResource AccentFillColorTertiaryBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorSecondaryBrush}" />
                        </MultiTrigger>

                        <!--  Checked + flyout open: both halves read pressed (WinUI CheckedFlyoutOpen).  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition SourceName="PART_SecondaryButton" Property="IsChecked" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PrimaryFill" Property="Background" Value="{DynamicResource AccentFillColorTertiaryBrush}" />
                            <Setter TargetName="SecondaryFill" Property="Background" Value="{DynamicResource AccentFillColorTertiaryBrush}" />
                        </MultiTrigger>

                        <!--  Checked + disabled (WinUI CheckedDisabled; disabled text, not on-accent).  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition Property="IsEnabled" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PrimaryFill" Property="Background" Value="{DynamicResource AccentFillColorDisabledBrush}" />
                            <Setter TargetName="SecondaryFill" Property="Background" Value="{DynamicResource AccentFillColorDisabledBrush}" />
                            <Setter TargetName="PrimaryStroke" Property="BorderBrush" Value="{DynamicResource ControlFillColorTransparentBrush}" />
                            <Setter TargetName="SecondaryStroke" Property="BorderBrush" Value="{DynamicResource ControlFillColorTransparentBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Style.Triggers>
            <Trigger Property="Appearance" Value="Accent">
                <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource AccentControlElevationBorderBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
            </Trigger>
            <!--
                Checked rest fills flow through TemplateBinding Background into both halves;
                declared last so checked wins over Accent. Foreground is deliberately NOT set
                here: style triggers outrank template triggers on the templated parent, so a
                style-level Foreground would override the template's checked-pressed and
                checked-disabled foreground transitions. The checked-rest template trigger
                owns the on-accent foreground instead.
            -->
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource AccentControlElevationBorderBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
