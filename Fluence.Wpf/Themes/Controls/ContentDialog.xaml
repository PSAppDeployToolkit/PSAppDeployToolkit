<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Fluence.Wpf.Controls">

    <!--
        Fluent Design ContentDialog style.
        Authority: WinUI 3 ContentDialog_themeresources.xaml (ContentDialogMaxWidth 548,
        ContentDialogMinWidth 320, ContentDialogMinHeight 184, ContentDialogPadding 24,
        button spacing 8, title 20px SemiBold). Surface: ContentDialogBackground =
        SolidBackgroundFillColorBase, ContentDialogTopOverlay = LayerFillColorAlt,
        ContentDialogBorderBrush = SurfaceStrokeColorDefault,
        ContentDialogSeparatorBorderBrush = CardStrokeColorDefault. The smoke layer
        (SmokeFillColorDefaultBrush) is painted by the host adorner in ContentDialog.cs,
        and the ~250ms opacity + 1.05-to-1.0 scale entrance is driven from code when the
        dialog is overlay-hosted (see ContentDialog.BeginOpenAnimation).
        No DropShadowEffect on the surface Border - WPF bitmap effects on a Border with
        CornerRadius produce artifacts (see DropDownButton.xaml); the smoke layer already
        separates the dialog from the window content beneath.
        Command buttons share three equal star columns; a column collapses to zero width
        when its button text is empty, and 4px half-margins produce the 8px WinUI gap
        between adjacent visible buttons.
    -->
    <Style TargetType="{x:Type controls:ContentDialog}">
        <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorBaseBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SurfaceStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="FontFamily" Value="{DynamicResource FluentFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="MaxWidth" Value="548" />
        <Setter Property="MinHeight" Value="184" />
        <Setter Property="MinWidth" Value="320" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ContentDialog}">
                    <Border
                        x:Name="DialogSurface"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{DynamicResource OverlayCornerRadius}"
                        UseLayoutRounding="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Border
                                x:Name="ContentArea"
                                Grid.Row="0"
                                Padding="24"
                                Background="{DynamicResource LayerFillColorAltBrush}"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                BorderThickness="0,0,0,1"
                                CornerRadius="8,8,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <ContentPresenter
                                        x:Name="TitlePresenter"
                                        Grid.Row="0"
                                        Margin="0,0,0,12"
                                        Content="{TemplateBinding Title}"
                                        ContentTemplate="{TemplateBinding TitleTemplate}"
                                        TextElement.FontSize="20"
                                        TextElement.FontWeight="SemiBold"
                                        TextElement.Foreground="{TemplateBinding Foreground}" />
                                    <ScrollViewer
                                        x:Name="ContentScrollViewer"
                                        Grid.Row="1"
                                        HorizontalScrollBarVisibility="Disabled"
                                        VerticalScrollBarVisibility="Auto">
                                        <ContentPresenter
                                            x:Name="BodyPresenter"
                                            TextElement.FontFamily="{TemplateBinding FontFamily}"
                                            TextElement.FontSize="{TemplateBinding FontSize}"
                                            TextElement.Foreground="{TemplateBinding Foreground}" />
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                            <Grid
                                x:Name="CommandSpace"
                                Grid.Row="1"
                                Margin="24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="PrimaryColumn" Width="*" />
                                    <ColumnDefinition x:Name="SecondaryColumn" Width="*" />
                                    <ColumnDefinition x:Name="CloseColumn" Width="*" />
                                </Grid.ColumnDefinitions>
                                <controls:Button
                                    x:Name="PART_PrimaryButton"
                                    Grid.Column="0"
                                    MinWidth="0"
                                    Margin="0,0,4,0"
                                    HorizontalAlignment="Stretch"
                                    Appearance="Accent"
                                    Content="{TemplateBinding PrimaryButtonText}"
                                    IsEnabled="{TemplateBinding IsPrimaryButtonEnabled}" />
                                <controls:Button
                                    x:Name="PART_SecondaryButton"
                                    Grid.Column="1"
                                    MinWidth="0"
                                    Margin="4,0,4,0"
                                    HorizontalAlignment="Stretch"
                                    Content="{TemplateBinding SecondaryButtonText}"
                                    IsEnabled="{TemplateBinding IsSecondaryButtonEnabled}" />
                                <controls:Button
                                    x:Name="PART_CloseButton"
                                    Grid.Column="2"
                                    MinWidth="0"
                                    Margin="4,0,0,0"
                                    HorizontalAlignment="Stretch"
                                    Content="{TemplateBinding CloseButtonText}" />
                            </Grid>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Title" Value="{x:Null}">
                            <Setter TargetName="TitlePresenter" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="TitlePresenter" Property="Margin" Value="0" />
                        </Trigger>
                        <Trigger Property="PrimaryButtonText" Value="">
                            <Setter TargetName="PART_PrimaryButton" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PrimaryColumn" Property="Width" Value="0" />
                        </Trigger>
                        <Trigger Property="SecondaryButtonText" Value="">
                            <Setter TargetName="PART_SecondaryButton" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="SecondaryColumn" Property="Width" Value="0" />
                        </Trigger>
                        <Trigger Property="CloseButtonText" Value="">
                            <Setter TargetName="PART_CloseButton" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="CloseColumn" Property="Width" Value="0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

</ResourceDictionary>
