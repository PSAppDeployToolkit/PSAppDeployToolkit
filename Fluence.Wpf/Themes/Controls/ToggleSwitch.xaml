<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Fluence.Wpf.Controls">

    <Style x:Key="ToggleSwitchFocusVisual">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Grid>
                        <Border
                            Margin="-3"
                            BorderBrush="{DynamicResource FocusStrokeColorOuterBrush}"
                            BorderThickness="2"
                            CornerRadius="{DynamicResource ControlCornerRadius}" />
                        <Border
                            Margin="-2"
                            BorderBrush="{DynamicResource FocusStrokeColorInnerBrush}"
                            BorderThickness="1"
                            CornerRadius="3" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:ToggleSwitch}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource ToggleSwitchFocusVisual}" />
        <Setter Property="FontFamily" Value="{DynamicResource FluentFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="Padding" Value="8,0,0,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ToggleSwitch}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  Header  -->
                        <ContentPresenter
                            x:Name="HeaderPresenter"
                            Grid.Row="0"
                            Margin="0,0,0,4"
                            Content="{TemplateBinding HeaderContent}"
                            TextBlock.FontFamily="{TemplateBinding FontFamily}"
                            TextBlock.FontSize="14"
                            TextBlock.Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                        <!--  Switch row: track + content  -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!--  Track  -->
                            <Grid
                                x:Name="TrackHost"
                                Grid.Column="0"
                                Width="40"
                                Height="20"
                                Background="Transparent">

                                <!--  Off track: normal  -->
                                <Border
                                    x:Name="TrackOff"
                                    Background="{DynamicResource ControlAltFillColorSecondaryBrush}"
                                    BorderBrush="{DynamicResource ControlStrongStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10" />

                                <!--  Off track: hover  -->
                                <Border
                                    x:Name="TrackOffHover"
                                    Background="{DynamicResource ControlAltFillColorTertiaryBrush}"
                                    BorderBrush="{DynamicResource ControlStrongStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Opacity="0" />

                                <!--  Off track: pressed  -->
                                <Border
                                    x:Name="TrackOffPressed"
                                    Background="{DynamicResource ControlAltFillColorQuarternaryBrush}"
                                    BorderBrush="{DynamicResource ControlStrongStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Opacity="0" />

                                <!--
                                    Internal opaque sub-layer that sits beneath the accent track
                                    when the switch is ON. The accent fill brushes
                                    (AccentFillColorDefault at full opacity, Secondary at 0.9,
                                    Tertiary at 0.8) composite against this opaque surface
                                    rather than the visible card around the toggle, so hover
                                    and pressed shades match the canonical Windows accent
                                    palette regardless of whether the surrounding card is
                                    translucent (CardBackgroundFillColorDefaultBrush over Mica)
                                    or opaque (SolidBackgroundFillColorBaseBrush).
                                    Opacity tracks the ON state via the same trigger as TrackOn.
                                -->
                                <Border
                                    x:Name="TrackBase"
                                    Background="{DynamicResource AccentFillBackdropBrush}"
                                    CornerRadius="10"
                                    Opacity="0" />

                                <!--  On track: normal  -->
                                <Border
                                    x:Name="TrackOn"
                                    Background="{DynamicResource AccentFillColorDefaultBrush}"
                                    CornerRadius="10"
                                    Opacity="0" />

                                <!--  On track: hover  -->
                                <Border
                                    x:Name="TrackOnHover"
                                    Background="{DynamicResource AccentFillColorSecondaryBrush}"
                                    CornerRadius="10"
                                    Opacity="0" />

                                <!--  On track: pressed  -->
                                <Border
                                    x:Name="TrackOnPressed"
                                    Background="{DynamicResource AccentFillColorTertiaryBrush}"
                                    CornerRadius="10"
                                    Opacity="0" />

                                <Grid
                                    x:Name="SwitchKnob"
                                    Width="20"
                                    Height="20"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    RenderTransformOrigin="0.5,0.5">
                                    <Grid.RenderTransform>
                                        <TranslateTransform x:Name="SwitchKnobTranslate" X="0" />
                                    </Grid.RenderTransform>

                                    <!--  Thumb: fixed 12x12 circle; hover/pressed/drag growth runs on the render-thread scale below.  -->
                                    <Ellipse
                                        x:Name="SwitchThumb"
                                        Width="12"
                                        Height="12"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Fill="{DynamicResource TextFillColorSecondaryBrush}"
                                        RenderTransformOrigin="0.5,0.5">
                                        <Ellipse.RenderTransform>
                                            <ScaleTransform x:Name="SwitchThumbScale" ScaleX="1" ScaleY="1" />
                                        </Ellipse.RenderTransform>
                                    </Ellipse>
                                </Grid>

                                <Thumb
                                    x:Name="PART_SwitchThumbInput"
                                    Background="Transparent"
                                    Focusable="False"
                                    Opacity="0" />
                            </Grid>

                            <!--  Off content (visible by default)  -->
                            <ContentPresenter
                                x:Name="OffContentPresenter"
                                Grid.Column="1"
                                Margin="{TemplateBinding Padding}"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding OffContent}"
                                ContentTemplate="{TemplateBinding OffContentTemplate}"
                                TextElement.FontFamily="{TemplateBinding FontFamily}"
                                TextElement.FontSize="{TemplateBinding FontSize}" />

                            <!--  On content (collapsed by default)  -->
                            <ContentPresenter
                                x:Name="OnContentPresenter"
                                Grid.Column="1"
                                Margin="{TemplateBinding Padding}"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding OnContent}"
                                ContentTemplate="{TemplateBinding OnContentTemplate}"
                                TextElement.FontFamily="{TemplateBinding FontFamily}"
                                TextElement.FontSize="{TemplateBinding FontSize}"
                                Visibility="Collapsed" />
                        </Grid>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!--  Collapse header when null  -->
                        <Trigger Property="HeaderContent" Value="{x:Null}">
                            <Setter TargetName="HeaderPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <!--  WI-3 B12: WinUI canonical knob easing - ControlFastOutSlowIn (0.8,0,0,1), ControlFasterAnimationDuration 83ms  -->
                        <!--  Hover (any state): grow thumb 12->14  -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SwitchThumb" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)">
                                            <SplineDoubleKeyFrame
                                                KeySpline="0.8,0,0,1"
                                                KeyTime="0:0:0.083"
                                                Value="1.1667" />
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SwitchThumb" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)">
                                            <SplineDoubleKeyFrame
                                                KeySpline="0.8,0,0,1"
                                                KeyTime="0:0:0.083"
                                                Value="1.1667" />
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SwitchThumb" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)">
                                            <SplineDoubleKeyFrame
                                                KeySpline="0.8,0,0,1"
                                                KeyTime="0:0:0.083"
                                                Value="1.0" />
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SwitchThumb" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)">
                                            <SplineDoubleKeyFrame
                                                KeySpline="0.8,0,0,1"
                                                KeyTime="0:0:0.083"
                                                Value="1.0" />
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>

                        <!--
                            Keyboard press (space, no pointer over): snap the thumb to the
                            pressed 17x14 footprint via the render scale. Replaces the old
                            steady-state Width/Height Setters; pointer presses on the track
                            are driven from code-behind, and pointer presses over the label
                            keep the hover storyboard value exactly as before.
                        -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsPressed" Value="True" />
                                <Condition Property="IsMouseOver" Value="False" />
                            </MultiTrigger.Conditions>
                            <MultiTrigger.EnterActions>
                                <BeginStoryboard x:Name="SwitchThumbKeyPressedStoryboard">
                                    <Storyboard>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SwitchThumb" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)">
                                            <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="1.4167" />
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SwitchThumb" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)">
                                            <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="1.1667" />
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.EnterActions>
                            <MultiTrigger.ExitActions>
                                <RemoveStoryboard BeginStoryboardName="SwitchThumbKeyPressedStoryboard" />
                            </MultiTrigger.ExitActions>
                        </MultiTrigger>

                        <!--  Unchecked + Hover  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="TrackOffHover" Property="Opacity" Value="1" />
                        </MultiTrigger>

                        <!--  Unchecked + Pressed: squash thumb to 17x14  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsPressed" Value="True" />
                                <Condition Property="IsChecked" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="TrackOffPressed" Property="Opacity" Value="1" />
                        </MultiTrigger>

                        <!--  Checked  -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="SwitchThumb" Property="Fill" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
                            <Setter TargetName="TrackOff" Property="Opacity" Value="0" />
                            <Setter TargetName="TrackOffHover" Property="Opacity" Value="0" />
                            <Setter TargetName="TrackOffPressed" Property="Opacity" Value="0" />
                            <Setter TargetName="TrackBase" Property="Opacity" Value="1" />
                            <Setter TargetName="TrackOn" Property="Opacity" Value="1" />
                            <Setter TargetName="OffContentPresenter" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="OnContentPresenter" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <!--  Checked + Hover  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsPressed" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="TrackOn" Property="Opacity" Value="0" />
                            <Setter TargetName="TrackOnHover" Property="Opacity" Value="1" />
                        </MultiTrigger>

                        <!--  Checked + Pressed: squash thumb  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition Property="IsPressed" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="TrackOn" Property="Opacity" Value="0" />
                            <Setter TargetName="TrackOnHover" Property="Opacity" Value="0" />
                            <Setter TargetName="TrackOnPressed" Property="Opacity" Value="1" />
                        </MultiTrigger>

                        <!--  Off + Disabled  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsEnabled" Value="False" />
                                <Condition Property="IsChecked" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="TrackOff" Property="Background" Value="{DynamicResource ControlAltFillColorDisabledBrush}" />
                            <Setter TargetName="TrackOffHover" Property="Background" Value="{DynamicResource ControlAltFillColorDisabledBrush}" />
                            <Setter TargetName="TrackOffPressed" Property="Background" Value="{DynamicResource ControlAltFillColorDisabledBrush}" />
                            <Setter TargetName="TrackOff" Property="BorderBrush" Value="{DynamicResource ControlStrongStrokeColorDisabledBrush}" />
                            <Setter TargetName="SwitchThumb" Property="Fill" Value="{DynamicResource TextFillColorDisabledBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
                            <Setter TargetName="SwitchThumb" Property="Opacity" Value="0.4" />
                        </MultiTrigger>

                        <!--  On + Disabled  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsEnabled" Value="False" />
                                <Condition Property="IsChecked" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="TrackOn" Property="Background" Value="{DynamicResource AccentFillColorDisabledBrush}" />
                            <Setter TargetName="SwitchThumb" Property="Fill" Value="{DynamicResource TextOnAccentFillColorDisabledBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
                            <Setter TargetName="SwitchThumb" Property="Opacity" Value="0.4" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

</ResourceDictionary>
