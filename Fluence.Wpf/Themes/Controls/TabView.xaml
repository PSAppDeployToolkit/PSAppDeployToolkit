<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Fluence.Wpf.Controls">

    <BooleanToVisibilityConverter x:Key="TabViewBooleanToVisibilityConverter" />

    <!--  TabViewItem: header with icon, content, close button  -->
    <Style TargetType="{x:Type controls:TabViewItem}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FocusVisualStyle" Value="{DynamicResource DefaultCollectionFocusVisualStyle}" />
        <Setter Property="FontFamily" Value="{DynamicResource FluentFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        <Setter Property="IsTabStop" Value="True" />
        <Setter Property="Margin" Value="0,0,6,0" />
        <Setter Property="MaxWidth" Value="240" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="MinWidth" Value="100" />
        <Setter Property="Padding" Value="12,0,8,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:TabViewItem}">
                    <Grid x:Name="Root" ClipToBounds="False">
                        <Border
                            x:Name="HoverBackground"
                            Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                            CornerRadius="8,8,0,0"
                            Opacity="0" />
                        <Border
                            x:Name="SelectedBackground"
                            Margin="0,0,0,-1"
                            Background="{DynamicResource SolidBackgroundFillColorTertiaryBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultSolidBrush}"
                            BorderThickness="1,1,1,0"
                            CornerRadius="8,8,0,0"
                            Opacity="0" />

                        <Grid Margin="{TemplateBinding Padding}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ContentPresenter
                                x:Name="IconHost"
                                Grid.Column="0"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding Icon}"
                                TextElement.Foreground="{TemplateBinding Foreground}"
                                Visibility="Collapsed">
                                <ContentPresenter.Resources>
                                    <!--  Icon follows the tab header text (SplitButton precedent): the scoped implicit style outranks the FontIcon theme-style Foreground; a consumer's local Foreground still wins.  -->
                                    <Style TargetType="{x:Type controls:FontIcon}">
                                        <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type controls:TabViewItem}}}" />
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>

                            <ContentPresenter
                                x:Name="HeaderHost"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                ContentSource="Header"
                                RecognizesAccessKey="True"
                                TextElement.FontFamily="{TemplateBinding FontFamily}"
                                TextElement.FontSize="{TemplateBinding FontSize}"
                                TextElement.Foreground="{TemplateBinding Foreground}" />

                            <Button
                                x:Name="PART_CloseButton"
                                Grid.Column="2"
                                Width="20"
                                Height="20"
                                Margin="6,0,0,0"
                                Padding="0"
                                VerticalAlignment="Center"
                                AutomationProperties.Name="Close tab"
                                Background="Transparent"
                                BorderThickness="0"
                                Focusable="False"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                ToolTip="Close tab">
                                <Button.Template>
                                    <ControlTemplate TargetType="{x:Type Button}">
                                        <Border
                                            x:Name="ButtonRoot"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="{DynamicResource ControlCornerRadius}">
                                            <Path
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Data="M 0 0 L 8 8 M 8 0 L 0 8"
                                                Stroke="{TemplateBinding Foreground}"
                                                StrokeThickness="1.5" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ButtonRoot" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="ButtonRoot" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <Border
                            x:Name="SelectionIndicator"
                            Height="3"
                            Margin="10,0,10,0"
                            VerticalAlignment="Bottom"
                            Background="{DynamicResource AccentFillColorDefaultBrush}"
                            CornerRadius="2"
                            Opacity="0"
                            RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="IndicatorScale" ScaleX="0" ScaleY="1" />
                            </Border.RenderTransform>
                        </Border>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="HoverBackground" Property="Opacity" Value="1" />
                        </Trigger>

                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                            <Setter TargetName="SelectedBackground" Property="Opacity" Value="1" />
                            <Setter Property="Panel.ZIndex" Value="1" />
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <!--  Indicator reveal: fade ControlFasterAnimationDuration (83 ms), scale ControlFastAnimationDuration (167 ms)  -->
                                        <DoubleAnimation
                                            Storyboard.TargetName="SelectionIndicator"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1"
                                            Duration="0:0:0.083" />
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="IndicatorScale" Storyboard.TargetProperty="ScaleX">
                                            <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                                            <SplineDoubleKeyFrame
                                                KeySpline="0.8,0,0,1"
                                                KeyTime="0:0:0.167"
                                                Value="1" />
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <!--  Indicator exit: ControlPressAnimationDuration (100 ms), fade delayed by ControlFasterAnimationDuration (83 ms)  -->
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="IndicatorScale" Storyboard.TargetProperty="ScaleX">
                                            <SplineDoubleKeyFrame
                                                KeySpline="0.8,0,0,1"
                                                KeyTime="0:0:0.1"
                                                Value="0" />
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimation
                                            BeginTime="0:0:0.083"
                                            Storyboard.TargetName="SelectionIndicator"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0"
                                            Duration="0:0:0.1" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
                        </Trigger>

                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="IconHost" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <DataTrigger Binding="{Binding Icon, RelativeSource={RelativeSource Self}, Converter={x:Static controls:FluenceWindow.IsNotNullConverter}}" Value="True">
                            <Setter TargetName="IconHost" Property="Visibility" Value="Visible" />
                        </DataTrigger>

                        <Trigger Property="IsClosable" Value="False">
                            <Setter TargetName="PART_CloseButton" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding CloseButtonOverlayMode, RelativeSource={RelativeSource AncestorType={x:Type controls:TabView}}}" Value="Auto" />
                                <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="False" />
                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="PART_CloseButton" Property="Visibility" Value="Hidden" />
                        </MultiDataTrigger>

                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding CloseButtonOverlayMode, RelativeSource={RelativeSource AncestorType={x:Type controls:TabView}}}" Value="OnPointerOver" />
                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="PART_CloseButton" Property="Visibility" Value="Hidden" />
                        </MultiDataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="UseLayoutRounding" Value="True" />

        <Style.Triggers>
            <DataTrigger Binding="{Binding TabWidthMode, RelativeSource={RelativeSource AncestorType={x:Type controls:TabView}}}" Value="Equal">
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            </DataTrigger>
            <DataTrigger Binding="{Binding TabWidthMode, RelativeSource={RelativeSource AncestorType={x:Type controls:TabView}}}" Value="Compact">
                <Setter Property="MinWidth" Value="48" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!--  TabView: horizontally scrollable strip + add button + content  -->
    <Style TargetType="{x:Type controls:TabView}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontFamily" Value="{DynamicResource FluentFontFamily}" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:TabView}">
                    <Grid x:Name="RootGrid" KeyboardNavigation.TabNavigation="Continue">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!--
                            Tab strip: [ScrollBack] [Scrollable tabs] [ScrollForward] [AddTab]
                            Scroll buttons are managed by TabView.UpdateScrollButtonVisibility():
                            they start Collapsed and appear only when tab content overflows.
                        -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!--  WI-3 B16: scroll-back button (WinUI TabView canonical)  -->
                            <RepeatButton
                                x:Name="PART_ScrollBackButton"
                                Grid.Column="0"
                                Width="28"
                                Height="28"
                                Margin="2,4,0,0"
                                Padding="0"
                                VerticalAlignment="Center"
                                AutomationProperties.Name="Scroll tabs backward"
                                Background="Transparent"
                                BorderThickness="0"
                                Delay="400"
                                Focusable="False"
                                Interval="100"
                                ToolTip="Scroll tabs backward"
                                Visibility="Collapsed">
                                <RepeatButton.Template>
                                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                                        <Border
                                            x:Name="ScrollBackRoot"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="{DynamicResource ControlCornerRadius}">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                FontSize="12"
                                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                Text="&#xE76B;" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ScrollBackRoot" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="ScrollBackRoot" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RepeatButton.Template>
                            </RepeatButton>

                            <ScrollViewer
                                x:Name="PART_TabContentScroller"
                                Grid.Column="1"
                                Focusable="False"
                                HorizontalScrollBarVisibility="Hidden"
                                PanningMode="HorizontalOnly"
                                VerticalScrollBarVisibility="Disabled">
                                <!--
                                    Use StackPanel instead of TabPanel.
                                    TabPanel applies selection-aware overlap offsets (±1 px) that
                                    shift the active-tab arrangement rect, causing the right border
                                    and top-right corner radius to be clipped.  StackPanel lays
                                    items out sequentially; Panel.ZIndex on the selected item
                                    handles all z-ordering through our visual-state triggers.
                                -->
                                <StackPanel
                                    x:Name="HeaderPanel"
                                    IsItemsHost="True"
                                    KeyboardNavigation.TabIndex="1"
                                    Orientation="Horizontal" />
                            </ScrollViewer>

                            <!--  WI-3 B16: scroll-forward button (WinUI TabView canonical)  -->
                            <RepeatButton
                                x:Name="PART_ScrollForwardButton"
                                Grid.Column="2"
                                Width="28"
                                Height="28"
                                Margin="0,4,0,0"
                                Padding="0"
                                VerticalAlignment="Center"
                                AutomationProperties.Name="Scroll tabs forward"
                                Background="Transparent"
                                BorderThickness="0"
                                Delay="400"
                                Focusable="False"
                                Interval="100"
                                ToolTip="Scroll tabs forward"
                                Visibility="Collapsed">
                                <RepeatButton.Template>
                                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                                        <Border
                                            x:Name="ScrollForwardRoot"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="{DynamicResource ControlCornerRadius}">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                FontSize="12"
                                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                Text="&#xE76C;" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ScrollForwardRoot" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="ScrollForwardRoot" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RepeatButton.Template>
                            </RepeatButton>

                            <Button
                                x:Name="PART_AddTabButton"
                                Grid.Column="3"
                                Width="32"
                                Height="32"
                                Margin="4,4,0,0"
                                Padding="0"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                Focusable="False"
                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                ToolTip="Add new tab"
                                Visibility="{Binding IsAddTabButtonVisible, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource TabViewBooleanToVisibilityConverter}}">
                                <Button.Template>
                                    <ControlTemplate TargetType="{x:Type Button}">
                                        <Border
                                            x:Name="AddButtonRoot"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="{DynamicResource ControlCornerRadius}">
                                            <Path
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Data="M 0 5 L 10 5 M 5 0 L 5 10"
                                                Stroke="{TemplateBinding Foreground}"
                                                StrokeThickness="1" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="AddButtonRoot" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="AddButtonRoot" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <Border
                            x:Name="ContentPanel"
                            Grid.Row="1"
                            Margin="0,-1,0,0"
                            Background="{DynamicResource SolidBackgroundFillColorTertiaryBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultSolidBrush}"
                            BorderThickness="1"
                            CornerRadius="0,0,8,8"
                            KeyboardNavigation.DirectionalNavigation="Contained"
                            KeyboardNavigation.TabIndex="2"
                            KeyboardNavigation.TabNavigation="Continue">
                            <ContentPresenter
                                x:Name="PART_SelectedContentHost"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                ContentSource="SelectedContent" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

</ResourceDictionary>
