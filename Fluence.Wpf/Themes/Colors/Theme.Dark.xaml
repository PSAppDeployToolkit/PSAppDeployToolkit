    <Color x:Key="LayerOnMicaBaseAltFillColorTertiary">#FF2C2C2C</Color>
    <Color x:Key="LayerOnMicaBaseAltFillColorTransparent">#00FFFFFF</Color>

    <!--  Solid Background Fill Colors  -->
    <Color x:Key="SolidBackgroundFillColorBase">#FF202020</Color>
    <Color x:Key="SolidBackgroundFillColorSecondary">#FF1C1C1C</Color>
    <Color x:Key="SolidBackgroundFillColorTertiary">#FF282828</Color>
    <Color x:Key="SolidBackgroundFillColorQuarternary">#FF2C2C2C</Color>
    <Color x:Key="SolidBackgroundFillColorTransparent">#00202020</Color>
    <Color x:Key="SolidBackgroundFillColorQuinary">#FF333333</Color>
    <Color x:Key="SolidBackgroundFillColorSenary">#FF373737</Color>
    <Color x:Key="SolidBackgroundFillColorBaseAlt">#FF0A0A0A</Color>

    <!--  Acrylic Background Fill Colors  -->
    <Color x:Key="AcrylicBackgroundFillColorDefault">#F02C2C2C</Color>
    <Color x:Key="AcrylicBackgroundFillColorBase">#FF1C1C1C</Color>

    <!--  System Fill Colors  -->
    <Color x:Key="SystemFillColorAttention">#FF60CDFF</Color>
    <Color x:Key="SystemFillColorInformational">#FF8A8A8A</Color>
    <Color x:Key="SystemFillColorSuccess">#FF6CCB5F</Color>
    <Color x:Key="SystemFillColorCaution">#FFFCE100</Color>
    <Color x:Key="SystemFillColorCritical">#FFFF99A4</Color>
    <Color x:Key="SystemFillColorNeutral">#8BFFFFFF</Color>
    <Color x:Key="SystemFillColorSolidNeutral">#FF9D9D9D</Color>
    <Color x:Key="SystemFillColorAttentionBackground">#08FFFFFF</Color>
    <Color x:Key="SystemFillColorSuccessBackground">#FF393D1B</Color>
    <Color x:Key="SystemFillColorCautionBackground">#FF433519</Color>
    <Color x:Key="SystemFillColorCriticalBackground">#FF442726</Color>
    <Color x:Key="SystemFillColorNeutralBackground">#08FFFFFF</Color>
    <Color x:Key="SystemFillColorSolidAttentionBackground">#FF2E2E2E</Color>
    <Color x:Key="SystemFillColorSolidNeutralBackground">#FF2E2E2E</Color>

    <!--  Window Chrome - Close Button  -->
    <Color x:Key="WindowCloseFillColorHover">#FFC42B1C</Color>
    <Color x:Key="WindowCloseFillColorPressed">#FFB4271C</Color>
    <Color x:Key="WindowCloseForegroundHover">#FFFFFFFF</Color>
    <Color x:Key="WindowCloseForegroundPressed">#FFFFFFFF</Color>

    <!--  Accent Fill Colors  -->
    <Color x:Key="AccentFillColorDisabled">#28FFFFFF</Color>

    <!--
        Text color for content placed on an accent-color background.
        Dark theme: black (accent is desaturated/lighter in dark mode).
        Authority: WinUI 3 Common_themeresources_any.xaml, Default (Dark) dictionary.
    -->
    <Color x:Key="TextOnAccentFillColorPrimary">#FF000000</Color>
    <Color x:Key="TextOnAccentFillColorSecondary">#80000000</Color>
    <Color x:Key="TextOnAccentFillColorDisabled">#87FFFFFF</Color>

    <!--
        WinUI 3 canonical: NavigationViewContentBackground = LayerFillColorDefault
        (#4C3A3A3A in dark = 30%-opaque grey #3A3A3A). This is a translucent "layer"
        brush, NOT fully transparent. Layered over the Mica/Acrylic backdrop it gives
        the content area a calm, slightly tinted surface while still letting some Mica
        through so card lifts and brand colors stay visible. Fully transparent
        (the previous overcorrection) lets raw Mica noise dominate the content area
        and washes out card differentiation.
    -->
    <Color x:Key="NavigationViewContentBackground">#4C3A3A3A</Color>

    <!--
        AccentFillBackdrop: opaque sub-layer behind the accent track inside the ToggleSwitch
        template. See Theme.Light.xaml for the rationale. Dark value matches
        SolidBackgroundFillColorBase so accent composited at 0.9 opacity yields the canonical
        Windows accent palette hover shade (e.g. #4CC2FF x 0.9 over #202020 = #48B2E9).
    -->
    <Color x:Key="AccentFillBackdrop">#FF202020</Color>

</ResourceDictionary>
