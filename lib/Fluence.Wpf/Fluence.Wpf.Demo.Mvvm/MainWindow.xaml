<ui:FluenceWindow
    x:Class="Fluence.Wpf.Demo.Mvvm.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Fluence.Wpf.Demo.Mvvm.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="clr-namespace:Fluence.Wpf.Controls;assembly=Fluence.Wpf"
    xmlns:vm="clr-namespace:Fluence.Wpf.Demo.Mvvm.ViewModels"
    Title="Task Manager - Fluence.Wpf MVVM Demo"
    Width="680"
    Height="580"
    MinWidth="520"
    MinHeight="400"
    d:DataContext="{d:DesignInstance vm:MainViewModel,
                                     IsDesignTimeCreatable=True}"
    Background="{DynamicResource ApplicationBackgroundBrush}"
    CornerStyle="Round"
    ExtendsContentIntoTitleBar="False"
    Icon="Resources/fluence-wpf-appicon-256.ico"
    SystemBackdropType="Mica"
    UseLayoutRounding="True"
    mc:Ignorable="d">

    <ui:FluenceWindow.Resources>
        <converters:EnumToBoolConverter x:Key="EnumToBool" />
    </ui:FluenceWindow.Resources>

    <Grid Margin="24,16,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Row 0: Title  -->
        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,16"
            FontFamily="{DynamicResource FluentFontFamily}"
            FontSize="28"
            FontWeight="SemiBold"
            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
            Text="Task Manager" />

        <!--  Row 1: Filter RadioButtons  -->
        <StackPanel
            Grid.Row="1"
            Margin="0,0,0,12"
            Orientation="Horizontal">
            <ui:RadioButton
                Margin="0,0,16,0"
                Content="All"
                GroupName="FilterGroup"
                IsChecked="{Binding ActiveFilter, Mode=TwoWay, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static vm:FilterMode.All}}" />
            <ui:RadioButton
                Margin="0,0,16,0"
                Content="Pending"
                GroupName="FilterGroup"
                IsChecked="{Binding ActiveFilter, Mode=TwoWay, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static vm:FilterMode.Pending}}" />
            <ui:RadioButton
                Content="Completed"
                GroupName="FilterGroup"
                IsChecked="{Binding ActiveFilter, Mode=TwoWay, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static vm:FilterMode.Completed}}" />
        </StackPanel>

        <!--  Row 2: Task list  -->
        <ui:SmoothScrollViewer
            Grid.Row="2"
            Margin="0,0,0,12"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding DisplayedTasks}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:TaskItemViewModel}">
                        <Border
                            Margin="0,0,0,4"
                            Padding="12,10"
                            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource ControlCornerRadius}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ui:CheckBox
                                    Grid.Column="0"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center"
                                    IsChecked="{Binding IsCompleted, Mode=TwoWay}" />

                                <TextBlock
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    FontFamily="{DynamicResource FluentFontFamily}"
                                    FontSize="14"
                                    Text="{Binding Title}"
                                    TextWrapping="Wrap">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                                                    <Setter Property="TextDecorations" Value="Strikethrough" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!--
                                    RelativeSource walk to Window is deliberate: TaskItemViewModel
                                    stays free of parent references. This DataTemplate must remain
                                    hosted directly inside this window (not moved into a UserControl).
                                -->
                                <ui:Button
                                    Grid.Column="2"
                                    Width="30"
                                    Height="30"
                                    Margin="8,0,0,0"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    ToolTip="Delete task">
                                    <ui:FontIcon Glyph="&#xE74D;" IconFontSize="12" />
                                </ui:Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ui:SmoothScrollViewer>

        <!--  Row 3: Add input  -->
        <Grid Grid.Row="3" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ui:TextBox
                Grid.Column="0"
                PlaceholderText="New task…"
                Text="{Binding NewTaskText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                <ui:TextBox.InputBindings>
                    <KeyBinding Key="Return" Command="{Binding AddCommand}" />
                </ui:TextBox.InputBindings>
            </ui:TextBox>

            <ui:Button
                Grid.Column="2"
                MinWidth="80"
                Appearance="Accent"
                Command="{Binding AddCommand}"
                Content="Add" />
        </Grid>

        <!--  Row 4: Footer  -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <ui:ProgressBar
                    Margin="0,0,0,4"
                    Maximum="100"
                    Minimum="0"
                    Value="{Binding ProgressValue, Mode=OneWay}" />
                <TextBlock
                    FontFamily="{DynamicResource FluentFontFamily}"
                    FontSize="12"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="{Binding StatusText, Mode=OneWay}" />
            </StackPanel>

            <ui:Button
                Grid.Column="2"
                MinWidth="120"
                VerticalAlignment="Bottom"
                Command="{Binding ClearCompletedCommand}"
                Content="Clear Completed" />
        </Grid>
    </Grid>
</ui:FluenceWindow>
