<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  Windows 11 Fluent Light Theme - Color-only layer  -->
    <!--  Brushes and accent ramp are built in C# by the FluenceThemeEngine pipeline.  -->

    <!--  Application Background  -->
    <Color x:Key="ApplicationBackgroundColor">#FFFAFAFA</Color>

    <!--  Keyboard Focus  -->
    <Color x:Key="KeyboardFocusBorderColor">#BE000000</Color>

    <!--  Text Fill Colors  -->
    <Color x:Key="TextFillColorPrimary">#E4000000</Color>
    <Color x:Key="TextFillColorSecondary">#9E000000</Color>
    <Color x:Key="TextFillColorTertiary">#72000000</Color>
    <Color x:Key="TextFillColorDisabled">#5C000000</Color>
    <Color x:Key="TextPlaceholderColor">#9E000000</Color>
    <Color x:Key="TextFillColorInverse">#FFFFFFFF</Color>

    <!--  Control Fill Colors  -->
    <Color x:Key="ControlFillColorDefault">#B3FFFFFF</Color>
    <Color x:Key="ControlFillColorSecondary">#80F9F9F9</Color>
    <Color x:Key="ControlFillColorTertiary">#4DF9F9F9</Color>
    <Color x:Key="ControlFillColorQuarternary">#C2F3F3F3</Color>
    <Color x:Key="ControlFillColorDisabled">#4DF9F9F9</Color>
    <Color x:Key="ControlFillColorTransparent">#00FFFFFF</Color>
    <Color x:Key="ControlFillColorInputActive">#FFFFFFFF</Color>

    <!--  Control Strong Fill Colors  -->
    <Color x:Key="ControlStrongFillColorDefault">#72000000</Color>
    <Color x:Key="ControlStrongFillColorDisabled">#51000000</Color>

    <!--  Control Solid Fill Colors  -->
    <Color x:Key="ControlSolidFillColorDefault">#FFFFFFFF</Color>

    <!--  Subtle Fill Colors  -->
    <Color x:Key="SubtleFillColorTransparent">#00FFFFFF</Color>
    <Color x:Key="SubtleFillColorSecondary">#09000000</Color>
    <Color x:Key="SubtleFillColorTertiary">#06000000</Color>
    <Color x:Key="SubtleFillColorDisabled">#00FFFFFF</Color>

    <!--  Control Alt Fill Colors  -->
    <Color x:Key="ControlAltFillColorTransparent">#00FFFFFF</Color>
    <Color x:Key="ControlAltFillColorSecondary">#06000000</Color>
    <Color x:Key="ControlAltFillColorTertiary">#0F000000</Color>
    <Color x:Key="ControlAltFillColorQuarternary">#18000000</Color>
    <Color x:Key="ControlAltFillColorDisabled">#00FFFFFF</Color>

    <!--  Control On Image Fill Colors  -->
    <Color x:Key="ControlOnImageFillColorDefault">#C9FFFFFF</Color>
    <Color x:Key="ControlOnImageFillColorSecondary">#FFF3F3F3</Color>
    <Color x:Key="ControlOnImageFillColorTertiary">#FFEBEBEB</Color>
    <Color x:Key="ControlOnImageFillColorDisabled">#00FFFFFF</Color>

    <!--  Control Stroke Colors  -->
    <Color x:Key="ControlStrokeColorDefault">#0F000000</Color>
    <Color x:Key="ControlStrokeColorSecondary">#29000000</Color>
    <!--  Seam between the NavigationView pane/header and the content presenter. Matches ControlStrokeColorSecondary in Light, but is intentionally fainter in Dark.  -->
    <Color x:Key="NavigationViewContentSeparator">#29000000</Color>
    <Color x:Key="ControlStrokeColorTertiary">#9E000000</Color>
    <Color x:Key="ControlStrokeColorOnAccentDefault">#14FFFFFF</Color>
    <Color x:Key="ControlStrokeColorOnAccentSecondary">#66000000</Color>
    <Color x:Key="ControlStrokeColorOnAccentTertiary">#37000000</Color>
    <Color x:Key="ControlStrokeColorOnAccentDisabled">#0F000000</Color>
    <Color x:Key="ControlStrokeColorForStrongFillWhenOnImage">#59FFFFFF</Color>

    <!--  Card Stroke Colors  -->
    <Color x:Key="CardStrokeColorDefault">#0F000000</Color>
    <Color x:Key="CardStrokeColorDefaultSolid">#FFEBEBEB</Color>

    <!--  Control Strong Stroke Colors  -->
    <Color x:Key="ControlStrongStrokeColorDefault">#72000000</Color>
    <Color x:Key="ControlStrongStrokeColorDisabled">#37000000</Color>

    <!--  Surface Stroke Colors  -->
    <Color x:Key="SurfaceStrokeColorDefault">#66757575</Color>
    <Color x:Key="SurfaceStrokeColorFlyout">#0F000000</Color>
    <Color x:Key="SurfaceStrokeColorInverse">#15FFFFFF</Color>

    <!--  Divider Stroke Color  -->
    <Color x:Key="DividerStrokeColorDefault">#0F000000</Color>

    <!--  Focus Stroke Colors  -->
    <Color x:Key="FocusStrokeColorOuter">#E4000000</Color>
    <Color x:Key="FocusStrokeColorInner">#B3FFFFFF</Color>

    <!--  Card Background Fill Colors  -->
    <Color x:Key="CardBackgroundFillColorDefault">#B3FFFFFF</Color>
    <Color x:Key="CardBackgroundFillColorSecondary">#80F6F6F6</Color>
    <Color x:Key="CardBackgroundFillColorTertiary">#FFFFFFFF</Color>

    <!--  Smoke Fill Color  -->
    <Color x:Key="SmokeFillColorDefault">#4D000000</Color>

    <!--  Layer Fill Colors  -->
    <Color x:Key="LayerFillColorDefault">#80FFFFFF</Color>
    <Color x:Key="LayerFillColorAlt">#FFFFFFFF</Color>
    <Color x:Key="LayerOnAcrylicFillColorDefault">#40FFFFFF</Color>
    <Color x:Key="LayerOnAccentAcrylicFillColorDefault">#40FFFFFF</Color>

    <!--  Layer On Mica Base Alt Fill Colors  -->
    <Color x:Key="LayerOnMicaBaseAltFillColorDefault">#B3FFFFFF</Color>
    <Color x:Key="LayerOnMicaBaseAltFillColorSecondary">#0A000000</Color>
    <Color x:Key="LayerOnMicaBaseAltFillColorTertiary">#FFF9F9F9</Color>
    <Color x:Key="LayerOnMicaBaseAltFillColorTransparent">#00000000</Color>

    <!--  Solid Background Fill Colors  -->
    <Color x:Key="SolidBackgroundFillColorBase">#FFF3F3F3</Color>
    <Color x:Key="SolidBackgroundFillColorSecondary">#FFEEEEEE</Color>
    <Color x:Key="SolidBackgroundFillColorTertiary">#FFF9F9F9</Color>
    <Color x:Key="SolidBackgroundFillColorQuarternary">#FFFFFFFF</Color>
    <Color x:Key="SolidBackgroundFillColorTransparent">#00F3F3F3</Color>
    <Color x:Key="SolidBackgroundFillColorQuinary">#FFFDFDFD</Color>
    <Color x:Key="SolidBackgroundFillColorSenary">#FFFFFFFF</Color>
    <Color x:Key="SolidBackgroundFillColorBaseAlt">#FFDADADA</Color>

    <!--  Acrylic Background Fill Colors  -->
    <Color x:Key="AcrylicBackgroundFillColorDefault">#F0F9F9F9</Color>
    <Color x:Key="AcrylicBackgroundFillColorBase">#FFEEEEEE</Color>

    <!--  System Fill Colors  -->
    <Color x:Key="SystemFillColorAttention">#FF0078D4</Color>
    <Color x:Key="SystemFillColorInformational">#FF8A8A8A</Color>
    <Color x:Key="SystemFillColorSuccess">#FF0F7B0F</Color>
    <Color x:Key="SystemFillColorCaution">#FF9D5D00</Color>
    <Color x:Key="SystemFillColorCritical">#FFC42B1C</Color>
    <Color x:Key="SystemFillColorNeutral">#72000000</Color>
    <Color x:Key="SystemFillColorSolidNeutral">#FF8A8A8A</Color>
    <Color x:Key="SystemFillColorAttentionBackground">#80F6F6F6</Color>
    <Color x:Key="SystemFillColorSuccessBackground">#FFDFF6DD</Color>
    <Color x:Key="SystemFillColorCautionBackground">#FFFFF4CE</Color>
    <Color x:Key="SystemFillColorCriticalBackground">#FFFDE7E9</Color>
    <Color x:Key="SystemFillColorNeutralBackground">#06000000</Color>
    <Color x:Key="SystemFillColorSolidAttentionBackground">#FFF7F7F7</Color>
    <Color x:Key="SystemFillColorSolidNeutralBackground">#FFF3F3F3</Color>

    <!--  Window Chrome - Close Button  -->
    <!--  These are the canonical Fluent close-button reds (#C42B1C / #B4271C).  -->
    <!--  Unlike SystemFillColorCritical they are identical in Light and Dark;  -->
    <!--  using tokens here lets High Contrast override via the resource system.  -->
    <Color x:Key="WindowCloseFillColorHover">#FFC42B1C</Color>
    <Color x:Key="WindowCloseFillColorPressed">#FFB4271C</Color>
    <Color x:Key="WindowCloseForegroundHover">#FFFFFFFF</Color>
    <Color x:Key="WindowCloseForegroundPressed">#FFFFFFFF</Color>


    <!--  Accent Fill Colors  -->
    <Color x:Key="AccentFillColorDisabled">#37000000</Color>

    <!--
        Text color for content placed on an accent-color background.
        Light theme: white (accent is dark/saturated blue).
        Authority: WinUI 3 Common_themeresources_any.xaml, Light dictionary.
    -->
    <Color x:Key="TextOnAccentFillColorPrimary">#FFFFFFFF</Color>
    <Color x:Key="TextOnAccentFillColorSecondary">#B3FFFFFF</Color>
    <Color x:Key="TextOnAccentFillColorDisabled">#FFFFFFFF</Color>

    <!--
        WinUI 3 canonical: NavigationViewContentBackground = LayerFillColorDefault
        (#80FFFFFF in light = 50%-opaque white). This is a translucent "layer" brush,
        NOT fully transparent. Layered over the Mica/Acrylic backdrop it gives the
        content area a calm, slightly tinted surface while still letting some Mica
        through so card lifts and brand colors stay visible.
    -->
    <Color x:Key="NavigationViewContentBackground">#80FFFFFF</Color>

    <!--
        AccentFillBackdrop: opaque sub-layer sitting BEHIND the accent track inside the
        ToggleSwitch template. The accent track uses AccentFillColor*Brush (Default at full
        opacity, Secondary at 0.9, Tertiary at 0.8); composing those against the visible card
        surface yields wallpaper-tinted hover/pressed shades on Mica that drift from
        Notepad/WinUI 3 references by 2-3 RGB units per channel. Layering them over an
        opaque white internal base in Light mode pins the composited result to the canonical
        Windows accent palette regardless of how translucent the surrounding card is.
    -->
    <Color x:Key="AccentFillBackdrop">#FFFFFFFF</Color>

</ResourceDictionary>
