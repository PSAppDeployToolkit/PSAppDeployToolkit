<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Fluence.Wpf.Controls"
    xmlns:ui="clr-namespace:Fluence.Wpf">

    <Style TargetType="{x:Type controls:Card}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="FontFamily" Value="{DynamicResource FluentFontFamily}" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:Card}">
                    <Border
                        x:Name="OuterBorder"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                        <Border
                            x:Name="ShadowHost"
                            Background="Transparent"
                            CornerRadius="{TemplateBinding CornerRadius}">
                            <Border x:Name="CardRoot" CornerRadius="{TemplateBinding CornerRadius}">
                                <Grid>
                                    <Border
                                        x:Name="VariantBackground"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{TemplateBinding CornerRadius}"
                                        UseLayoutRounding="True" />
                                    <Border
                                        x:Name="ClickHoverLayer"
                                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                        CornerRadius="{TemplateBinding CornerRadius}"
                                        Opacity="0" />
                                    <Border
                                        x:Name="ClickPressLayer"
                                        Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                        CornerRadius="{TemplateBinding CornerRadius}"
                                        Opacity="0" />
                                    <Grid Margin="{TemplateBinding Padding}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition x:Name="HeaderRow" Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid
                                            x:Name="HeaderPanel"
                                            Grid.Row="0"
                                            Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter
                                                x:Name="IconPresenter"
                                                Grid.Column="0"
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center"
                                                Content="{TemplateBinding Icon}"
                                                TextElement.Foreground="{TemplateBinding Foreground}">
                                                <ContentPresenter.Resources>
                                                    <!--  Icon follows the header text (SplitButton precedent): the scoped implicit style outranks the FontIcon theme-style Foreground; a consumer's local Foreground still wins.  -->
                                                    <Style TargetType="{x:Type controls:FontIcon}">
                                                        <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type controls:Card}}}" />
                                                    </Style>
                                                </ContentPresenter.Resources>
                                            </ContentPresenter>
                                            <ContentPresenter
                                                x:Name="HeaderPresenter"
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Content="{TemplateBinding Header}"
                                                ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                TextElement.FontFamily="{TemplateBinding FontFamily}"
                                                TextElement.Foreground="{TemplateBinding Foreground}" />
                                        </Grid>
                                        <ContentPresenter
                                            x:Name="ContentPresenter"
                                            Grid.Row="1"
                                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                            ContentSource="Content"
                                            TextElement.FontFamily="{TemplateBinding FontFamily}"
                                            TextElement.Foreground="{TemplateBinding Foreground}" />
                                        <ContentPresenter
                                            x:Name="FooterPresenter"
                                            Grid.Row="2"
                                            Margin="0,8,0,0"
                                            Content="{TemplateBinding Footer}"
                                            ContentTemplate="{TemplateBinding FooterTemplate}" />
                                    </Grid>
                                </Grid>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="ClickableStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver" />
                                        <VisualState x:Name="Pressed" />
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Border>
                        </Border>
                    </Border>
                    <ControlTemplate.Resources>
                        <!--  WI-3 C21: subtle elevation for Default variant only (BlurRadius=8, Opacity=0.08).  -->
                        <DropShadowEffect
                            x:Key="CardDefaultElevationEffect"
                            BlurRadius="8"
                            Direction="270"
                            Opacity="0.08"
                            ShadowDepth="2"
                            Color="Black" />
                        <Storyboard x:Key="HoverOnStoryboard">
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ClickHoverLayer" Storyboard.TargetProperty="Opacity">
                                <SplineDoubleKeyFrame
                                    KeySpline="0.8,0,0,1"
                                    KeyTime="0:0:0.1"
                                    Value="1" />
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>
                        <Storyboard x:Key="HoverOffStoryboard">
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ClickHoverLayer" Storyboard.TargetProperty="Opacity">
                                <SplineDoubleKeyFrame
                                    KeySpline="0.8,0,0,1"
                                    KeyTime="0:0:0.1"
                                    Value="0" />
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>
                        <Storyboard x:Key="PressOnStoryboard">
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ClickPressLayer" Storyboard.TargetProperty="Opacity">
                                <SplineDoubleKeyFrame
                                    KeySpline="0.8,0,0,1"
                                    KeyTime="0:0:0.1"
                                    Value="1" />
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>
                        <Storyboard x:Key="PressOffStoryboard">
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ClickPressLayer" Storyboard.TargetProperty="Opacity">
                                <SplineDoubleKeyFrame
                                    KeySpline="0.8,0,0,1"
                                    KeyTime="0:0:0.1"
                                    Value="0" />
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>
                    </ControlTemplate.Resources>
                    <ControlTemplate.Triggers>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Header" Value="{x:Null}" />
                                <Condition Property="Icon" Value="{x:Null}" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="HeaderRow" Property="Height" Value="0" />
                            <Setter TargetName="HeaderPanel" Property="Margin" Value="0" />
                            <Setter TargetName="HeaderPanel" Property="Visibility" Value="Collapsed" />
                        </MultiTrigger>
                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="IconPresenter" Property="Margin" Value="0" />
                            <Setter TargetName="IconPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Header" Value="{x:Null}">
                            <Setter TargetName="HeaderPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Footer" Value="{x:Null}">
                            <Setter TargetName="FooterPresenter" Property="Margin" Value="0" />
                            <Setter TargetName="FooterPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <Trigger Property="Variant" Value="{x:Static ui:CardVariant.Default}">
                            <Setter TargetName="OuterBorder" Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
                            <Setter TargetName="VariantBackground" Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
                            <Setter TargetName="VariantBackground" Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
                            <Setter TargetName="VariantBackground" Property="BorderThickness" Value="1" />
                            <!--  WI-3 C21: Default variant gets subtle elevation shadow.  -->
                            <Setter TargetName="OuterBorder" Property="Effect" Value="{StaticResource CardDefaultElevationEffect}" />
                        </Trigger>
                        <Trigger Property="Variant" Value="{x:Static ui:CardVariant.Outlined}">
                            <Setter TargetName="OuterBorder" Property="Background" Value="Transparent" />
                            <Setter TargetName="VariantBackground" Property="Background" Value="Transparent" />
                            <Setter TargetName="VariantBackground" Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
                            <Setter TargetName="VariantBackground" Property="BorderThickness" Value="1" />
                        </Trigger>
                        <Trigger Property="Variant" Value="{x:Static ui:CardVariant.Filled}">
                            <Setter TargetName="OuterBorder" Property="Background" Value="{DynamicResource CardBackgroundFillColorSecondaryBrush}" />
                            <Setter TargetName="VariantBackground" Property="Background" Value="{DynamicResource CardBackgroundFillColorSecondaryBrush}" />
                            <Setter TargetName="VariantBackground" Property="BorderThickness" Value="0" />
                        </Trigger>
                        <Trigger Property="Variant" Value="{x:Static ui:CardVariant.Subtle}">
                            <Setter TargetName="OuterBorder" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                            <Setter TargetName="VariantBackground" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                            <Setter TargetName="VariantBackground" Property="BorderThickness" Value="0" />
                        </Trigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsClickable" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsPressed" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter Property="Cursor" Value="Hand" />
                            <MultiTrigger.EnterActions>
                                <BeginStoryboard Storyboard="{StaticResource HoverOnStoryboard}" />
                            </MultiTrigger.EnterActions>
                            <MultiTrigger.ExitActions>
                                <BeginStoryboard Storyboard="{StaticResource HoverOffStoryboard}" />
                            </MultiTrigger.ExitActions>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsClickable" Value="True" />
                                <Condition Property="IsPressed" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter Property="Cursor" Value="Hand" />
                            <MultiTrigger.EnterActions>
                                <BeginStoryboard Storyboard="{StaticResource PressOnStoryboard}" />
                            </MultiTrigger.EnterActions>
                            <MultiTrigger.ExitActions>
                                <BeginStoryboard Storyboard="{StaticResource PressOffStoryboard}" />
                            </MultiTrigger.ExitActions>
                        </MultiTrigger>
                        <Trigger Property="IsClickable" Value="True">
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="FocusVisualStyle" Value="{DynamicResource DefaultControlFocusVisualStyle}" />
                            <Setter Property="Focusable" Value="True" />
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="OuterBorder" Property="Background" Value="{DynamicResource ControlFillColorDisabledBrush}" />
                            <Setter TargetName="VariantBackground" Property="Background" Value="{DynamicResource ControlFillColorDisabledBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
                            <Setter TargetName="ClickHoverLayer" Property="Opacity" Value="0" />
                            <Setter TargetName="ClickPressLayer" Property="Opacity" Value="0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>
</ResourceDictionary>
