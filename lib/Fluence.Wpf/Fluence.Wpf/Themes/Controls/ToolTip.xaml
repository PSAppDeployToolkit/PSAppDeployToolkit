<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Fluence.Wpf.Controls">

    <!--
        Fluent Design ToolTip style.
        Authority: WinUI 3 ToolTip_themeresources.xaml (brush keys, font size, padding).
        Note: DropShadowEffect is intentionally omitted on the inner Border - WPF bitmap
        effects on a Border with CornerRadius produce squared-off artifacts at the rounded
        corners in a Popup (see DropDownButton.xaml). System drop shadow (HasDropShadow=True)
        is used instead, which is applied at the Popup window level without artifacts.
    -->
    <!--
        Suppress the system tooltip popup fade: WPF's ToolTip binds its internal host
        popup's PopupAnimation to this resource key (which resolves Fade while the OS
        "Fade or slide ToolTips into view" effect is on), and the template storyboard
        below owns the single WinUI-parity fade. Overriding the key here keeps exactly
        one fade - the FlyoutBase / TeachingTip PopupAnimation=None precedent, expressed
        as a theme resource because the tooltip pipeline creates its popup internally.
    -->
    <PopupAnimation x:Key="{x:Static SystemParameters.ToolTipPopupAnimationKey}">None</PopupAnimation>

    <Style TargetType="{x:Type controls:ToolTip}">
        <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorTertiaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SurfaceStrokeColorFlyoutBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontFamily" Value="{DynamicResource FluentFontFamily}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="HasDropShadow" Value="True" />
        <Setter Property="MaxWidth" Value="320" />
        <Setter Property="Padding" Value="9,6,9,8" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ToolTip}">
                    <Border
                        x:Name="ToolTipSurface"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{DynamicResource OverlayCornerRadius}"
                        UseLayoutRounding="True">
                        <ContentPresenter
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            TextElement.FontFamily="{TemplateBinding FontFamily}"
                            TextElement.FontSize="{TemplateBinding FontSize}"
                            TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <!--
                            Open fade, WinUI ToolTip_themeresources.xaml FadeInThemeAnimation
                            precedent: opacity 0 to 1 over 83ms (ControlFasterAnimationDuration)
                            on the 0.8,0,0,1 spline (ControlFastOutSlowInKeySpline);
                            Typography.xaml motion tokens, mirrored literally because storyboard
                            attributes cannot reference them. Opacity-only by design: tooltips
                            are a high-frequency surface (no translate/scale), and an
                            opacity-only entrance stays reduced-motion friendly without a code
                            gate. SourceName anchors the trigger to the template child so it
                            only hooks once the template has instantiated. No exit animation -
                            WinUI closes tooltips instantly.
                        -->
                        <EventTrigger RoutedEvent="FrameworkElement.Loaded" SourceName="ToolTipSurface">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ToolTipSurface" Storyboard.TargetProperty="Opacity">
                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                                        <SplineDoubleKeyFrame
                                            KeySpline="0.8,0,0,1"
                                            KeyTime="0:0:0.083"
                                            Value="1" />
                                    </DoubleAnimationUsingKeyFrames>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

</ResourceDictionary>
