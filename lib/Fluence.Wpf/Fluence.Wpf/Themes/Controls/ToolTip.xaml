<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Fluence.Wpf.Controls">

    <!--
        Fluent Design ToolTip style.
        Authority: WinUI 3 ToolTip_themeresources.xaml (brush keys, font size, padding).
        Note: DropShadowEffect is intentionally omitted on the inner Border - WPF bitmap
        effects on a Border with CornerRadius produce squared-off artifacts at the rounded
        corners in a Popup (see DropDownButton.xaml). System drop shadow (HasDropShadow=True)
        is used instead, which is applied at the Popup window level without artifacts.
    -->
    <Style TargetType="{x:Type controls:ToolTip}">
        <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorTertiaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SurfaceStrokeColorFlyoutBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontFamily" Value="{DynamicResource FluentFontFamily}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="HasDropShadow" Value="True" />
        <Setter Property="MaxWidth" Value="320" />
        <Setter Property="Padding" Value="9,6,9,8" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ToolTip}">
                    <Border
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{DynamicResource OverlayCornerRadius}"
                        UseLayoutRounding="True">
                        <ContentPresenter
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            TextElement.FontFamily="{TemplateBinding FontFamily}"
                            TextElement.FontSize="{TemplateBinding FontSize}"
                            TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

</ResourceDictionary>
