<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Fluence.Wpf.Controls">

    <!--
        Fluent Design ColorPicker style.
        Authority: WinUI 3 ColorPicker.xaml / ColorPicker_themeresources.xaml (spectrum
        square with a contrast-flipping selection ellipse, rounded 12px channel slider
        tracks over the live gradients, dual current/previous preview swatches, and a
        text-entry area with an optional More/Less toggle, an RGB/HSV representation
        selector, per-channel inputs, an alpha percentage input, and a hex input).
        Layout note: the spectrum is fixed to saturation (x) by value (y) at the selected
        hue with hue on a horizontal slider below (the third-dimension color slider),
        rather than WinUI's ColorSpectrumComponents permutations; see ColorPicker.cs for
        the scope notes.
        Every gradient (hue rainbow, alpha ramp, spectrum bitmap) and the checkerboard
        are generated by ColorPicker code-behind through the named borders below, so no
        literal colors appear in this template; chrome uses canonical theme tokens only.
        The channel sliders are stock WPF Sliders re-templated to a bare track so the
        full-width gradient underlay stays visible; they reuse the Fluence slider's
        SliderThumbStyle and SliderTrackSegmentStyle (Slider.xaml) for the thumb and the
        invisible-but-clickable track segments.
    -->

    <Style x:Key="ColorPickerChannelSliderStyle" TargetType="{x:Type Slider}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource DefaultControlFocusVisualStyle}" />
        <Setter Property="IsMoveToPointEnabled" Value="True" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Slider}">
                    <Grid Background="Transparent">
                        <Track
                            x:Name="PART_Track"
                            VerticalAlignment="Center"
                            Maximum="{TemplateBinding Maximum}"
                            Minimum="{TemplateBinding Minimum}"
                            Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Value, Mode=TwoWay}">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="Slider.DecreaseLarge" Style="{DynamicResource SliderTrackSegmentStyle}" />
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{DynamicResource SliderThumbStyle}" />
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="Slider.IncreaseLarge" Style="{DynamicResource SliderTrackSegmentStyle}" />
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <!--
        Subtle toggle for the More/Less button. The default ToggleButton renders its
        checked state as an accent fill (plus a press scale), which is wrong for the
        WinUI ColorPicker More button - that button is a flat subtle toggle whose checked
        state is conveyed by the "Less" label and the flipped chevron (both swapped by the
        ColorPicker template triggers). This style keeps it transparent with subtle
        hover/press tints and no accent or scale transform.
    -->
    <Style x:Key="ColorPickerMoreButtonStyle" TargetType="{x:Type controls:ToggleButton}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="FocusVisualStyle" Value="{DynamicResource DefaultControlFocusVisualStyle}" />
        <Setter Property="FontFamily" Value="{DynamicResource FluentFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Padding" Value="11,5,11,6" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ToggleButton}">
                    <Border
                        x:Name="MoreButtonFill"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{DynamicResource ControlCornerRadius}">
                        <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            RecognizesAccessKey="True"
                            TextElement.FontFamily="{TemplateBinding FontFamily}"
                            TextElement.FontSize="{TemplateBinding FontSize}"
                            TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MoreButtonFill" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="MoreButtonFill" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <Style TargetType="{x:Type controls:ColorPicker}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="FontFamily" Value="{DynamicResource FluentFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <!--
            IsTabStop=False: the outer ColorPicker shell must not be a tab stop. Keyboard
            focus belongs to the channel sliders and the hex text box. See TimePicker.xaml
            for the same pattern and rationale.
        -->
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ColorPicker}">
                    <Border
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!--  Saturation (x) by value (y) spectrum at the selected hue  -->
                            <Border
                                x:Name="SpectrumSection"
                                Grid.Row="0"
                                HorizontalAlignment="Left"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1">
                                <Grid
                                    x:Name="PART_SpectrumArea"
                                    Width="256"
                                    Height="256"
                                    AutomationProperties.Name="Color spectrum"
                                    Background="Transparent"
                                    Focusable="True"
                                    KeyboardNavigation.IsTabStop="True">
                                    <Image x:Name="PART_SpectrumImage" Stretch="Fill" />
                                    <Ellipse
                                        x:Name="PART_SpectrumThumb"
                                        Width="16"
                                        Height="16"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Fill="Transparent"
                                        IsHitTestVisible="False"
                                        StrokeThickness="2" />
                                </Grid>
                            </Border>

                            <!--  Hue channel: rainbow underlay painted by code-behind  -->
                            <Grid
                                x:Name="HueSection"
                                Grid.Row="1"
                                Height="32"
                                Margin="0,12,0,0">
                                <Border
                                    x:Name="HueGradientBorder"
                                    Height="12"
                                    VerticalAlignment="Center"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6" />
                                <Slider
                                    x:Name="PART_HueSlider"
                                    LargeChange="30"
                                    Maximum="360"
                                    Minimum="0"
                                    SmallChange="1"
                                    Style="{StaticResource ColorPickerChannelSliderStyle}" />
                            </Grid>

                            <!--  Alpha channel: checkerboard + live gradient painted by code-behind  -->
                            <Grid
                                x:Name="AlphaSection"
                                Grid.Row="2"
                                Height="32"
                                Margin="0,12,0,0">
                                <Border
                                    x:Name="AlphaCheckerboardBorder"
                                    Height="12"
                                    VerticalAlignment="Center"
                                    CornerRadius="6" />
                                <Border
                                    x:Name="AlphaGradientBorder"
                                    Height="12"
                                    VerticalAlignment="Center"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6" />
                                <Slider
                                    x:Name="PART_AlphaSlider"
                                    LargeChange="16"
                                    Maximum="255"
                                    Minimum="0"
                                    SmallChange="1"
                                    Style="{StaticResource ColorPickerChannelSliderStyle}" />
                            </Grid>

                            <!--  Preview swatches: current color and optional previous color  -->
                            <Grid
                                x:Name="SwatchSection"
                                Grid.Row="3"
                                Height="24"
                                Margin="0,12,0,0">
                                <Border x:Name="SwatchCheckerboardBorder" CornerRadius="4" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border
                                        x:Name="CurrentSwatchBorder"
                                        Grid.Column="0"
                                        CornerRadius="4,0,0,4" />
                                    <Border
                                        x:Name="PreviousSwatchBorder"
                                        Grid.Column="1"
                                        CornerRadius="0,4,4,0" />
                                </Grid>
                                <Border
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4" />
                            </Grid>

                            <!--
                                Text entry: optional More/Less toggle above the representation
                                selector, the RGB/HSV channel inputs, the alpha percentage input,
                                and the hex input (WinUI ColorPicker text-entry layout). Channel
                                and alpha boxes commit live per keystroke via code-behind; the
                                hex box commits on Enter or focus loss.
                            -->
                            <StackPanel x:Name="TextEntryArea" Grid.Row="4">
                                <controls:ToggleButton
                                    x:Name="MoreButton"
                                    MinWidth="120"
                                    Margin="0,12,0,0"
                                    HorizontalAlignment="Right"
                                    AutomationProperties.Name="More options"
                                    Style="{StaticResource ColorPickerMoreButtonStyle}"
                                    Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="MoreButtonLabel" Text="More" />
                                        <controls:FontIcon
                                            x:Name="MoreButtonGlyph"
                                            Margin="8,0,0,0"
                                            Glyph="&#xE70D;"
                                            IconFontSize="12" />
                                    </StackPanel>
                                </controls:ToggleButton>
                                <Grid x:Name="TextEntryGrid" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <controls:ComboBox
                                        x:Name="ColorRepresentationComboBox"
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Width="120"
                                        HorizontalAlignment="Left"
                                        AutomationProperties.Name="Color model"
                                        SelectedIndex="0">
                                        <ComboBoxItem Content="RGB" />
                                        <ComboBoxItem Content="HSV" />
                                    </controls:ComboBox>
                                    <controls:TextBox
                                        x:Name="PART_HexTextBox"
                                        Grid.Row="0"
                                        Grid.Column="2"
                                        Width="132"
                                        VerticalAlignment="Top"
                                        AutomationProperties.Name="Hex"
                                        FontFamily="{TemplateBinding FontFamily}"
                                        FontSize="{TemplateBinding FontSize}"
                                        MaxLength="9" />
                                    <StackPanel
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="3">
                                        <StackPanel x:Name="ColorChannelTextInputPanel">
                                            <Grid x:Name="RgbChannelPanel">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <controls:TextBox
                                                    x:Name="PART_RedTextBox"
                                                    Grid.Row="0"
                                                    Grid.Column="0"
                                                    Width="120"
                                                    Margin="0,12,0,0"
                                                    AutomationProperties.Name="Red"
                                                    FontFamily="{TemplateBinding FontFamily}"
                                                    FontSize="{TemplateBinding FontSize}"
                                                    MaxLength="3" />
                                                <TextBlock
                                                    Grid.Row="0"
                                                    Grid.Column="2"
                                                    Margin="0,12,0,0"
                                                    VerticalAlignment="Center"
                                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                    Text="Red" />
                                                <controls:TextBox
                                                    x:Name="PART_GreenTextBox"
                                                    Grid.Row="1"
                                                    Grid.Column="0"
                                                    Width="120"
                                                    Margin="0,12,0,0"
                                                    AutomationProperties.Name="Green"
                                                    FontFamily="{TemplateBinding FontFamily}"
                                                    FontSize="{TemplateBinding FontSize}"
                                                    MaxLength="3" />
                                                <TextBlock
                                                    Grid.Row="1"
                                                    Grid.Column="2"
                                                    Margin="0,12,0,0"
                                                    VerticalAlignment="Center"
                                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                    Text="Green" />
                                                <controls:TextBox
                                                    x:Name="PART_BlueTextBox"
                                                    Grid.Row="2"
                                                    Grid.Column="0"
                                                    Width="120"
                                                    Margin="0,12,0,0"
                                                    AutomationProperties.Name="Blue"
                                                    FontFamily="{TemplateBinding FontFamily}"
                                                    FontSize="{TemplateBinding FontSize}"
                                                    MaxLength="3" />
                                                <TextBlock
                                                    Grid.Row="2"
                                                    Grid.Column="2"
                                                    Margin="0,12,0,0"
                                                    VerticalAlignment="Center"
                                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                    Text="Blue" />
                                            </Grid>
                                            <Grid x:Name="HsvChannelPanel" Visibility="Collapsed">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <controls:TextBox
                                                    x:Name="PART_HueTextBox"
                                                    Grid.Row="0"
                                                    Grid.Column="0"
                                                    Width="120"
                                                    Margin="0,12,0,0"
                                                    AutomationProperties.Name="Hue"
                                                    FontFamily="{TemplateBinding FontFamily}"
                                                    FontSize="{TemplateBinding FontSize}"
                                                    MaxLength="3" />
                                                <TextBlock
                                                    Grid.Row="0"
                                                    Grid.Column="2"
                                                    Margin="0,12,0,0"
                                                    VerticalAlignment="Center"
                                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                    Text="Hue" />
                                                <controls:TextBox
                                                    x:Name="PART_SaturationTextBox"
                                                    Grid.Row="1"
                                                    Grid.Column="0"
                                                    Width="120"
                                                    Margin="0,12,0,0"
                                                    AutomationProperties.Name="Saturation"
                                                    FontFamily="{TemplateBinding FontFamily}"
                                                    FontSize="{TemplateBinding FontSize}"
                                                    MaxLength="3" />
                                                <TextBlock
                                                    Grid.Row="1"
                                                    Grid.Column="2"
                                                    Margin="0,12,0,0"
                                                    VerticalAlignment="Center"
                                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                    Text="Saturation" />
                                                <controls:TextBox
                                                    x:Name="PART_ValueTextBox"
                                                    Grid.Row="2"
                                                    Grid.Column="0"
                                                    Width="120"
                                                    Margin="0,12,0,0"
                                                    AutomationProperties.Name="Value"
                                                    FontFamily="{TemplateBinding FontFamily}"
                                                    FontSize="{TemplateBinding FontSize}"
                                                    MaxLength="3" />
                                                <TextBlock
                                                    Grid.Row="2"
                                                    Grid.Column="2"
                                                    Margin="0,12,0,0"
                                                    VerticalAlignment="Center"
                                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                    Text="Value" />
                                            </Grid>
                                        </StackPanel>
                                        <Grid x:Name="AlphaInputPanel">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <controls:TextBox
                                                x:Name="PART_AlphaTextBox"
                                                Grid.Column="0"
                                                Width="120"
                                                Margin="0,12,0,0"
                                                AutomationProperties.Name="Opacity"
                                                FontFamily="{TemplateBinding FontFamily}"
                                                FontSize="{TemplateBinding FontSize}"
                                                MaxLength="4" />
                                            <TextBlock
                                                Grid.Column="2"
                                                Margin="0,12,0,0"
                                                VerticalAlignment="Center"
                                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                Text="Opacity" />
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsColorSpectrumVisible" Value="False">
                            <Setter TargetName="SpectrumSection" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsColorSliderVisible" Value="False">
                            <Setter TargetName="HueSection" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <!--  Alpha visibility flags AND with IsAlphaEnabled (either trigger collapses).  -->
                        <Trigger Property="IsAlphaEnabled" Value="False">
                            <Setter TargetName="AlphaSection" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="AlphaInputPanel" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PART_HexTextBox" Property="MaxLength" Value="7" />
                        </Trigger>
                        <Trigger Property="IsAlphaSliderVisible" Value="False">
                            <Setter TargetName="AlphaSection" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsAlphaTextInputVisible" Value="False">
                            <Setter TargetName="AlphaInputPanel" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsColorPreviewVisible" Value="False">
                            <Setter TargetName="SwatchSection" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsHexInputVisible" Value="False">
                            <Setter TargetName="PART_HexTextBox" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <!--  Channel collapse leaves the hex and alpha inputs; hex shifts left into the freed column.  -->
                        <Trigger Property="IsColorChannelTextInputVisible" Value="False">
                            <Setter TargetName="ColorRepresentationComboBox" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="ColorChannelTextInputPanel" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PART_HexTextBox" Property="Grid.Column" Value="0" />
                            <Setter TargetName="PART_HexTextBox" Property="HorizontalAlignment" Value="Left" />
                        </Trigger>
                        <Trigger Property="IsMoreButtonVisible" Value="True">
                            <Setter TargetName="MoreButton" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <!--  More mode: the text-entry grid stays collapsed until the toggle is checked.  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMoreButtonVisible" Value="True" />
                                <Condition SourceName="MoreButton" Property="IsChecked" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="TextEntryGrid" Property="Visibility" Value="Collapsed" />
                        </MultiTrigger>
                        <Trigger SourceName="MoreButton" Property="IsChecked" Value="True">
                            <Setter TargetName="MoreButtonLabel" Property="Text" Value="Less" />
                            <Setter TargetName="MoreButtonGlyph" Property="Glyph" Value="&#xE70E;" />
                            <Setter TargetName="MoreButton" Property="AutomationProperties.Name" Value="Less options" />
                        </Trigger>
                        <Trigger SourceName="ColorRepresentationComboBox" Property="SelectedIndex" Value="1">
                            <Setter TargetName="RgbChannelPanel" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="HsvChannelPanel" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="PreviousColor" Value="{x:Null}">
                            <Setter TargetName="PreviousSwatchBorder" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="CurrentSwatchBorder" Property="Grid.ColumnSpan" Value="2" />
                            <Setter TargetName="CurrentSwatchBorder" Property="CornerRadius" Value="4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="VerticalAlignment" Value="Top" />
    </Style>
</ResourceDictionary>
