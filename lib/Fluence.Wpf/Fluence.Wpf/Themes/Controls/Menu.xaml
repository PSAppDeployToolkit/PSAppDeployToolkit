<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Fluence.Wpf.Controls">

    <!--
        Fluent Design Menu (horizontal menu bar) style.
        Authority: WinUI 3 MenuBar_themeresources.xaml (brush keys, typography).
        The bar itself is transparent; it exposes top-level MenuItem entries that share
        the MenuItem style from ContextMenu.xaml (Fluent flyout popup on click).
    -->
    <Style TargetType="{x:Type controls:Menu}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontFamily" Value="{DynamicResource FluentFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <!--
                    Explicit template required: without it WPF falls back to the Aero-theme
                    system template for Menu which clamps the bar to MenuBarHeight (~19 px)
                    and prevents Fluence MenuItem items from rendering at their natural height.
                    Authority: .NET 10 WPF Menu.xaml generic template (ItemsPresenter pattern).
                -->
                <ControlTemplate TargetType="{x:Type controls:Menu}">
                    <Border
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        UseLayoutRounding="{TemplateBinding UseLayoutRounding}">
                        <ItemsPresenter />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

</ResourceDictionary>
