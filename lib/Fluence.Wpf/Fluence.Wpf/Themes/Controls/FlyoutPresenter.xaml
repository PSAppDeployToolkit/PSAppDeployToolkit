<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Fluence.Wpf.Controls">

    <!--
        Fluent Design FlyoutPresenter style.
        Authority: WinUI 3 Flyout_themeresources.xaml (FlyoutContentThemePadding 16,15,16,17;
        FlyoutThemeMinWidth 96 / MaxWidth 456 / MinHeight 40 / MaxHeight 758).
        Surface treatment reuses the canonical in-tree flyout tokens from ContextMenu.xaml /
        ToolTip.xaml: SolidBackgroundFillColorTertiaryBrush + SurfaceStrokeColorFlyoutBrush +
        OverlayCornerRadius.
        No DropShadowEffect on the Border - WPF bitmap effects on a Border with CornerRadius
        produce artifacts in a Popup (see DropDownButton.xaml).
    -->
    <Style TargetType="{x:Type controls:FlyoutPresenter}">
        <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorTertiaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SurfaceStrokeColorFlyoutBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontFamily" Value="{DynamicResource FluentFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="MaxHeight" Value="758" />
        <Setter Property="MaxWidth" Value="456" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="MinWidth" Value="96" />
        <Setter Property="Padding" Value="16,15,16,17" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:FlyoutPresenter}">
                    <Border
                        x:Name="PresenterSurface"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{DynamicResource OverlayCornerRadius}"
                        UseLayoutRounding="True">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="PresenterTranslate" />
                        </Border.RenderTransform>
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                TextElement.FontFamily="{TemplateBinding FontFamily}"
                                TextElement.FontSize="{TemplateBinding FontSize}"
                                TextElement.Foreground="{TemplateBinding Foreground}" />
                        </ScrollViewer>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!--
                            Open reveal, ContextMenu.xaml submenu precedent: slide from Y=-8 to 0 with
                            a fade 0 to 1 over 167ms on the 0.8,0,0,1 spline (Typography.xaml motion
                            tokens ControlFastAnimationDuration + ControlFastOutSlowInKeySpline;
                            storyboard attributes need literal values). The presenter cannot see
                            FlyoutBase.Placement from the template, so v1 uses this fixed reveal
                            matching the dominant bottom placement. FlyoutBase.cs sets the popup's
                            PopupAnimation to None so this storyboard owns the reveal.
                            SourceName anchors the trigger to the template child so it is only
                            hooked once the template has instantiated; a presenter whose Loaded
                            fires without an applied template (a collapsed declaration) would
                            otherwise fail to resolve the storyboard target names.
                        -->
                        <EventTrigger RoutedEvent="FrameworkElement.Loaded" SourceName="PresenterSurface">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PresenterTranslate" Storyboard.TargetProperty="Y">
                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="-8" />
                                        <SplineDoubleKeyFrame
                                            KeySpline="0.8,0,0,1"
                                            KeyTime="0:0:0.167"
                                            Value="0" />
                                    </DoubleAnimationUsingKeyFrames>
                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PresenterSurface" Storyboard.TargetProperty="Opacity">
                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                                        <SplineDoubleKeyFrame
                                            KeySpline="0.8,0,0,1"
                                            KeyTime="0:0:0.167"
                                            Value="1" />
                                    </DoubleAnimationUsingKeyFrames>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
    </Style>

</ResourceDictionary>
