<UserControl
    x:Class="Fluence.Wpf.Demo.Pages.GalleryAccessibilityPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:Fluence.Wpf.Demo.Pages"
    xmlns:ui="clr-namespace:Fluence.Wpf.Controls;assembly=Fluence.Wpf"
    xmlns:uicore="clr-namespace:Fluence.Wpf;assembly=Fluence.Wpf"
    d:DesignHeight="900"
    d:DesignWidth="900"
    mc:Ignorable="d">
    <ui:SmoothScrollViewer Style="{StaticResource GalleryPageScrollViewerStyle}">
        <StackPanel Style="{StaticResource GalleryPageContentStackStyle}">
            <TextBlock
                Margin="0,0,0,4"
                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                Style="{DynamicResource TitleTextBlockStyle}"
                Text="Accessibility" />
            <TextBlock
                Margin="0,0,0,24"
                Style="{StaticResource SectionDescriptionStyle}"
                Text="These examples show keyboard focus, tab order, high contrast brushes, automation names, and right-to-left layout in a simple code-behind demo." />

            <TextBlock
                Margin="0,0,0,4"
                Style="{StaticResource SectionHeaderStyle}"
                Text="Focus and tab order" />
            <TextBlock
                Margin="0,0,0,8"
                Style="{StaticResource SectionDescriptionStyle}"
                Text="Press Tab to move keyboard focus. Fluence controls render the two-tone focus ring and follow visual tab order unless TabIndex overrides it." />
            <ContentControl x:Name="DemoSampleSlot01DemoContentHost" Visibility="Collapsed">
                <StackPanel>
                    <Grid x:Name="KeyboardSupportPrimaryControls" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ui:Button
                            Grid.Row="0"
                            Grid.Column="0"
                            Margin="0,0,12,12"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            AutomationProperties.Name="First focusable button"
                            Content="Button 1" />
                        <ui:Button
                            Grid.Row="0"
                            Grid.Column="1"
                            Margin="0,0,12,12"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            AutomationProperties.Name="Second focusable button"
                            Content="Button 2" />
                        <ui:TextBox
                            Grid.Row="0"
                            Grid.Column="2"
                            Margin="0,8,12,12"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            AutomationProperties.Name="Focusable text input"
                            PlaceholderText="TextBox" />
                        <ui:ComboBox
                            Grid.Row="0"
                            Grid.Column="3"
                            Margin="0,0,0,12"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            AutomationProperties.Name="Focusable combo box">
                            <ComboBoxItem Content="Option A" IsSelected="True" />
                            <ComboBoxItem Content="Option B" />
                        </ui:ComboBox>
                        <ui:CheckBox
                            Grid.Row="1"
                            Grid.Column="0"
                            Margin="0,0,12,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            AutomationProperties.Name="Focusable checkbox"
                            Content="CheckBox" />
                        <ui:ToggleSwitch
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="0,0,12,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            AutomationProperties.Name="Focusable toggle" />
                        <ui:Slider
                            Grid.Row="1"
                            Grid.Column="2"
                            Margin="0,0,12,0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            AutomationProperties.Name="Focusable slider"
                            Maximum="100"
                            Minimum="0"
                            Value="40" />
                        <ui:HyperlinkButton
                            Grid.Row="1"
                            Grid.Column="3"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            AutomationProperties.Name="Focusable hyperlink"
                            Content="HyperlinkButton" />
                    </Grid>

                    <TextBlock
                        Margin="0,12,0,8"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Style="{DynamicResource CaptionTextBlockStyle}"
                        Text="The buttons below have an explicit reverse tab order: 3, 2, 1." />
                    <Grid
                        x:Name="KeyboardSupportExplicitOrderControls"
                        Margin="0,0,0,8"
                        KeyboardNavigation.TabNavigation="Local">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ui:Button
                            x:Name="ExplicitTabOrderThirdButton"
                            Grid.Column="0"
                            Margin="0,0,12,0"
                            HorizontalAlignment="Stretch"
                            Content="Tab order: 3"
                            TabIndex="3" />
                        <ui:Button
                            x:Name="ExplicitTabOrderSecondButton"
                            Grid.Column="1"
                            Margin="0,0,12,0"
                            HorizontalAlignment="Stretch"
                            Content="Tab order: 2"
                            TabIndex="2" />
                        <ui:Button
                            x:Name="ExplicitTabOrderFirstButton"
                            Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            Appearance="Accent"
                            Content="Tab order: 1 (first)"
                            TabIndex="1" />
                    </Grid>
                </StackPanel>
            </ContentControl>
            <pages:DemoSampleControl SampleDescription="Keyboard focus and explicit tab order." />

            <TextBlock
                Margin="0,0,0,4"
                Style="{StaticResource SectionHeaderStyle}"
                Text="High contrast brush mapping" />
            <TextBlock
                Margin="0,0,0,8"
                Style="{StaticResource SectionDescriptionStyle}"
                Text="In High Contrast mode, Fluence maps canonical WinUI keys to Windows system colors. Switch to High Contrast from Settings to verify contrast live." />
            <ContentControl x:Name="DemoSampleSlot02DemoContentHost" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Padding="12,8" Background="{DynamicResource ControlFillColorDefaultBrush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                Style="{DynamicResource BodyStrongTextBlockStyle}"
                                Text="Fluence key" />
                            <TextBlock
                                Grid.Column="1"
                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                Style="{StaticResource BodyStrongTextBlockStyle}"
                                Text="HC system color" />
                            <TextBlock
                                Grid.Column="2"
                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                Style="{StaticResource BodyStrongTextBlockStyle}"
                                Text="Live swatch" />
                        </Grid>
                    </Border>
                    <ItemsControl x:Name="HcMappingTable" Grid.Row="1">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Padding="12,6"
                                    BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Text="{Binding Key}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Text="{Binding HcMapping}" />
                                        <Border
                                            Grid.Column="2"
                                            Width="32"
                                            Height="16"
                                            HorizontalAlignment="Left"
                                            Background="{Binding Brush}"
                                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="2" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ContentControl>
            <pages:DemoSampleControl SampleDescription="High contrast remaps Fluence semantic brushes to Windows system colors." />

            <TextBlock
                Margin="0,0,0,4"
                Style="{StaticResource SectionHeaderStyle}"
                Text="Automation properties" />
            <TextBlock
                Margin="0,0,0,8"
                Style="{StaticResource SectionDescriptionStyle}"
                Text="Set AutomationProperties.Name for screen readers on controls that have no visible label." />
            <ContentControl x:Name="DemoSampleSlot03DemoContentHost" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,16"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource BodyTextBlockStyle}"
                        Text="These icon-only buttons all have AutomationProperties.Name so Narrator announces their purpose:"
                        TextWrapping="Wrap" />
                    <ui:StackPanel Orientation="Horizontal" Spacing="16">
                        <ui:Button
                            x:Name="AutomationNewDocumentButton"
                            Width="36"
                            Height="36"
                            MinWidth="36"
                            Margin="0,0,8,0"
                            Padding="0"
                            AutomationProperties.Name="New document">
                            <ui:FontIcon Glyph="&#xE8A5;" IconFontSize="18" />
                        </ui:Button>
                        <ui:Button
                            x:Name="AutomationOpenFileButton"
                            Width="36"
                            Height="36"
                            MinWidth="36"
                            Margin="0,0,8,0"
                            Padding="0"
                            AutomationProperties.Name="Open file">
                            <ui:FontIcon Glyph="&#xE8E5;" IconFontSize="18" />
                        </ui:Button>
                        <ui:Button
                            x:Name="AutomationSaveButton"
                            Width="36"
                            Height="36"
                            MinWidth="36"
                            Margin="0,0,8,0"
                            Padding="0"
                            AutomationProperties.Name="Save">
                            <ui:FontIcon Glyph="&#xE74E;" IconFontSize="18" />
                        </ui:Button>
                        <ui:Button
                            x:Name="AutomationDeleteButton"
                            Width="36"
                            Height="36"
                            MinWidth="36"
                            Margin="0,0,8,0"
                            Padding="0"
                            AutomationProperties.Name="Delete">
                            <ui:FontIcon Glyph="&#xE74D;" IconFontSize="18" />
                        </ui:Button>
                        <ui:Button
                            x:Name="AutomationShareButton"
                            Width="36"
                            Height="36"
                            MinWidth="36"
                            Padding="0"
                            AutomationProperties.Name="Share">
                            <ui:FontIcon Glyph="&#xE72D;" IconFontSize="18" />
                        </ui:Button>
                    </ui:StackPanel>
                    <TextBlock
                        Margin="0,12,0,0"
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="Tip: use Windows Narrator or Inspect.exe to verify automation names at runtime."
                        TextWrapping="Wrap" />
                </StackPanel>
            </ContentControl>
            <pages:DemoSampleControl SampleDescription="Icon-only buttons expose AutomationProperties.Name for screen readers." />

            <TextBlock
                Margin="0,0,0,4"
                Style="{StaticResource SectionHeaderStyle}"
                Text="Right-to-left (RTL) layout" />
            <TextBlock
                Margin="0,0,0,8"
                Style="{StaticResource SectionDescriptionStyle}"
                Text="Toggle FlowDirection=RightToLeft on a card to verify Fluence controls mirror correctly for Arabic, Hebrew, and Farsi locales." />
            <ContentControl x:Name="DemoSampleSlot04DemoContentHost" Visibility="Collapsed">
                <StackPanel>
                    <ui:ToggleSwitch
                        x:Name="RtlToggle"
                        Margin="0,0,0,12"
                        Checked="RtlToggle_Changed"
                        Content="Enable RTL on demo card"
                        IsChecked="True"
                        Unchecked="RtlToggle_Changed" />
                    <ui:Card
                        x:Name="RtlDemoCard"
                        Padding="16"
                        FlowDirection="RightToLeft"
                        Variant="{x:Static uicore:CardVariant.Outlined}">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,8"
                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                Style="{StaticResource BodyStrongTextBlockStyle}"
                                Text="نموذج عنصر تحكم" />
                            <StackPanel Orientation="Horizontal">
                                <ui:Button
                                    Margin="0,0,8,0"
                                    Appearance="Accent"
                                    Content="زر رئيسي" />
                                <ui:Button Content="إلغاء" />
                            </StackPanel>
                        </StackPanel>
                    </ui:Card>
                </StackPanel>
            </ContentControl>
            <pages:DemoSampleControl SampleDescription="Right-to-left layout mirrors Fluence controls for RTL locales." />

            <TextBlock
                Margin="0,0,0,4"
                Style="{StaticResource SectionHeaderStyle}"
                Text="Live region announcements" />
            <TextBlock
                Margin="0,0,0,8"
                Style="{StaticResource SectionDescriptionStyle}"
                Text="Fluence uses AutomationProperties.LiveSetting and LiveRegionChanged to announce status changes to screen readers on both net472 and net10. Trigger an InfoBar or a validation error below and listen with Narrator to hear the announcement." />
            <ContentControl x:Name="DemoSampleSlot05DemoContentHost" Visibility="Collapsed">
                <StackPanel>
                    <ui:StackPanel
                        Margin="0,0,0,12"
                        Orientation="Horizontal"
                        Spacing="8">
                        <ui:Button
                            x:Name="LiveRegionInfoButton"
                            Margin="0,0,8,0"
                            Appearance="Accent"
                            AutomationProperties.Name="Show informational announcement"
                            Click="LiveRegionInfoButton_Click"
                            Content="Show InfoBar" />
                        <ui:Button
                            x:Name="LiveRegionDismissButton"
                            AutomationProperties.Name="Dismiss announcement"
                            Click="LiveRegionDismissButton_Click"
                            Content="Dismiss" />
                    </ui:StackPanel>
                    <ui:InfoBar
                        x:Name="LiveRegionInfoBar"
                        Title="Live region demo"
                        IsClosable="True"
                        IsOpen="False"
                        Message="This message was announced by a live region when the InfoBar opened."
                        Severity="{x:Static uicore:InfoBarSeverity.Informational}" />
                    <TextBlock
                        Margin="0,8,0,16"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource BodyTextBlockStyle}"
                        Text="Validation error live region:"
                        TextWrapping="Wrap" />
                    <StackPanel Margin="0,0,0,0" Orientation="Horizontal">
                        <ui:TextBox
                            x:Name="LiveRegionValidationTextBox"
                            Width="200"
                            Margin="0,0,8,0"
                            AutomationProperties.Name="Email"
                            PlaceholderText="Enter an email address"
                            TextChanged="LiveRegionValidation_TextChanged" />
                        <TextBlock
                            x:Name="LiveRegionValidationStatus"
                            VerticalAlignment="Bottom"
                            Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="" />
                    </StackPanel>
                    <TextBlock
                        Margin="0,8,0,0"
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="Tip: run Windows Narrator (Win+Ctrl+Enter) and interact with these controls to hear live region announcements."
                        TextWrapping="Wrap" />
                </StackPanel>
            </ContentControl>
            <pages:DemoSampleControl SampleDescription="InfoBar and TextBox validation use LiveRegionChanged to announce status changes without interrupting the user." />

            <TextBlock
                Margin="0,0,0,4"
                Style="{StaticResource SectionHeaderStyle}"
                Text="RatingControl keyboard operability" />
            <TextBlock
                Margin="0,0,0,8"
                Style="{StaticResource SectionDescriptionStyle}"
                Text="RatingControl is fully keyboard-operable: Tab to focus it, then use Left/Right arrow keys to change the value, Home to clear to zero, and End to set the maximum. The automation peer exposes the RangeValue pattern so Narrator reports the current rating." />
            <ContentControl x:Name="DemoSampleSlot06DemoContentHost" Visibility="Collapsed">
                <StackPanel>
                    <ui:RatingControl
                        x:Name="A11yRatingControl"
                        Margin="0,0,0,8"
                        AutomationProperties.Name="Keyboard rating demo"
                        Caption="Use arrow keys to change the rating"
                        MaxRating="5"
                        Value="3" />
                    <TextBlock
                        x:Name="A11yRatingStatusText"
                        Margin="0,4,0,0"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="Current rating: 3 of 5" />
                    <TextBlock
                        Margin="0,12,0,0"
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="Tip: Narrator announces the rating change as you press the arrow keys because the peer exposes the RangeValue pattern."
                        TextWrapping="Wrap" />
                </StackPanel>
            </ContentControl>
            <pages:DemoSampleControl SampleDescription="RatingControl supports full keyboard navigation and exposes the RangeValue automation pattern." />
        </StackPanel>
    </ui:SmoothScrollViewer>
</UserControl>
